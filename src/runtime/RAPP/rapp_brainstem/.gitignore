# User creds (root-level)
.env

# Legacy runtime state at root (auto-migrated to ~/.brainstem/ on boot,
# but kept in .gitignore so pre-migration copies never get tracked)
.copilot_token
.copilot_session
.swarms.json
.agent_groups.json

# Local storage data (services, memory, etc.)
.brainstem_data/

# Python
__pycache__/
*.pyc

# macOS junk
.DS_Store

# Remote agents (downloaded at runtime)
.remote_agents/
.repos.json
voice.zip

# Local-only agents — auto-loaded by brainstem, never committed.
# Drop any *_agent.py here that's personal, half-baked, or tenant-specific.
agents/workspace_agents/local_agents/

# Project-scoped agent folders also stay local by default.
agents/workspace_agents/specific_local_project_agents*/
