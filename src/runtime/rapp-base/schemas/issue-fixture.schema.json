{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kody-w.github.io/rapp-base/schemas/issue-fixture.schema.json",
  "title": "Normalized local reconciliation fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repository",
    "issues"
  ],
  "properties": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "node_id",
        "full_name"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "node_id": {
          "type": "string"
        },
        "full_name": {
          "type": "string"
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "node_id",
          "number",
          "created_at",
          "updated_at",
          "user",
          "author_association",
          "labels",
          "body",
          "state",
          "title"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1
          },
          "node_id": {
            "type": "string"
          },
          "number": {
            "type": "integer",
            "minimum": 1
          },
          "created_at": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          },
          "user": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "author_association": {
            "type": "string"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "body": {
            "type": "string"
          },
          "state": {
            "enum": [
              "open",
              "closed"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
