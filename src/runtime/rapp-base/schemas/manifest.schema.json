{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kody-w.github.io/rapp-base/schemas/manifest.schema.json",
  "title": "RAPP Base manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "name",
    "profile",
    "description",
    "repository",
    "generated_at",
    "limits",
    "collections"
  ],
  "properties": {
    "schema": {
      "const": "rapp-base-manifest/1.0"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "const": "rapp-base/1.0"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "name",
        "branch"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "branch": {
          "const": "main"
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issue_body_bytes",
        "command_bytes",
        "json_depth",
        "json_nodes",
        "object_keys",
        "array_items",
        "string_bytes",
        "fields_per_collection",
        "records_per_collection",
        "snapshot_items",
        "generated_collection_bytes",
        "issues_per_reconcile",
        "requests",
        "events"
      ],
      "properties": {
        "issue_body_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65536
        },
        "command_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32768
        },
        "json_depth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        },
        "json_nodes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2048
        },
        "object_keys": {
          "type": "integer",
          "minimum": 1,
          "maximum": 256
        },
        "array_items": {
          "type": "integer",
          "minimum": 1,
          "maximum": 256
        },
        "string_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8192
        },
        "fields_per_collection": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        },
        "records_per_collection": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2000
        },
        "snapshot_items": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2000
        },
        "generated_collection_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8388608
        },
        "issues_per_reconcile": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "requests": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50000
        },
        "events": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50000
        }
      }
    },
    "collections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/collection"
      }
    }
  },
  "$defs": {
    "policy": {
      "enum": [
        "owner",
        "public",
        "collaborator",
        "maintainer",
        "disabled"
      ]
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "string",
            "number",
            "integer",
            "boolean",
            "string[]"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "unique": {
          "type": "boolean"
        },
        "enum": {
          "type": "array",
          "minItems": 1
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "minLength": {
          "type": "integer",
          "minimum": 0
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0
        },
        "format": {
          "const": "url"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "seed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "owner_id",
        "created_at",
        "data"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "owner_id": {
          "type": "integer",
          "minimum": 0
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "data": {
          "type": "object"
        }
      }
    },
    "collection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "policies",
        "fields",
        "seed"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]{0,62}$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "policies": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "create",
            "update",
            "delete"
          ],
          "properties": {
            "create": {
              "enum": [
                "public",
                "collaborator",
                "maintainer",
                "disabled"
              ]
            },
            "update": {
              "$ref": "#/$defs/policy"
            },
            "delete": {
              "$ref": "#/$defs/policy"
            }
          }
        },
        "fields": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/field"
          }
        },
        "seed": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/seed"
          }
        }
      }
    }
  }
}
