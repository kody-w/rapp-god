{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kody-w/rapp-messaging/main/schemas/memory-record.schema.json",
  "title": "RAPP Messaging Memory Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "content", "custodian_ids", "subject_ids", "provenance", "visibility", "allowed_audiences", "grants"],
  "properties": {
    "schema": { "const": "rapp-messaging-memory/1.0" },
    "id": { "type": "string", "minLength": 1 },
    "content": { "type": "string" },
    "kind": { "type": "string", "default": "fact" },
    "custodian_ids": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "subject_ids": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "conversation_id", "audience_id", "asserted_by"],
      "properties": {
        "event_id": { "type": "string" },
        "conversation_id": { "type": "string" },
        "audience_id": { "type": "string" },
        "asserted_by": { "type": "string" },
        "recorded_at": { "type": "string", "format": "date-time" }
      }
    },
    "visibility": { "enum": ["owner-private", "principal-private", "group-shared", "public"] },
    "allowed_audiences": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "grants": {
      "type": "array",
      "items": { "$ref": "consent-capability.schema.json" }
    },
    "legacy": { "type": "boolean", "default": false }
  }
}
