{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kody-w/rapp-messaging/main/schemas/consent-capability.schema.json",
  "title": "RAPP Messaging Consent Capability",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "capability_id", "action", "event_id", "principal_id", "memory_id", "audience_id", "roster_epoch", "issued_at", "consumed", "revoked"],
  "properties": {
    "schema": { "const": "rapp-messaging-consent/1.0" },
    "capability_id": { "type": "string", "minLength": 16 },
    "action": { "enum": ["share", "revoke", "forget"] },
    "event_id": { "type": "string", "minLength": 1 },
    "principal_id": { "type": "string", "minLength": 1 },
    "memory_id": { "type": "string", "minLength": 1 },
    "audience_id": { "type": "string", "minLength": 1 },
    "roster_epoch": { "type": "string", "minLength": 1 },
    "issued_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": ["string", "null"], "format": "date-time" },
    "consumed": { "type": "boolean" },
    "revoked": { "type": "boolean" }
  }
}
