{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kody-w/rapp-messaging/main/schemas/transport-binding.schema.json",
  "title": "RAPP Messaging Transport Binding",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "installation_id", "rappter_id", "transport", "account_id", "binding_id"],
  "properties": {
    "schema": { "const": "rapp-messaging-transport-binding/1.0" },
    "installation_id": { "type": "string", "minLength": 1 },
    "rappter_id": { "type": "string", "minLength": 1 },
    "transport": { "type": "string", "minLength": 1 },
    "account_id": { "type": "string", "minLength": 1 },
    "binding_id": {
      "type": "string",
      "description": "HMAC/content-addressed binding; never a raw phone/email/chat id.",
      "minLength": 16
    },
    "role": { "enum": ["owner", "principal", "group", "service"] },
    "active": { "type": "boolean", "default": true },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
