{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kody-w/rapp-messaging/main/schemas/conversation-context.schema.json",
  "title": "RAPP Messaging Conversation Context",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "conversation_id", "soul_id", "scope", "audience_id", "participant_ids", "roster_epoch"],
  "properties": {
    "schema": { "const": "rapp-messaging-conversation/1.0" },
    "conversation_id": { "type": "string", "minLength": 16 },
    "soul_id": { "type": "string", "minLength": 1 },
    "scope": { "enum": ["owner-private", "principal-private", "group-shared", "public"] },
    "principal_id": { "type": ["string", "null"] },
    "audience_id": { "type": "string", "minLength": 16 },
    "participant_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "roster_epoch": { "type": "string", "minLength": 1 },
    "source_event_id": { "type": ["string", "null"] },
    "allowed_tools": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  }
}
