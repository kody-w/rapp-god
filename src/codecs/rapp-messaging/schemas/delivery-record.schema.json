{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kody-w/rapp-messaging/main/schemas/delivery-record.schema.json",
  "title": "RAPP Messaging Delivery Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "event_id", "conversation_id", "direction", "state", "attempt_count", "created_at", "updated_at"],
  "properties": {
    "schema": { "const": "rapp-messaging-delivery/1.0" },
    "event_id": { "type": "string", "minLength": 1 },
    "conversation_id": { "type": "string", "minLength": 1 },
    "direction": { "enum": ["inbound", "outbound"] },
    "state": {
      "enum": [
        "observed", "claimed", "processed", "dropped", "retryable",
        "prepared", "attempted", "submitted", "unknown", "failed",
        "delivered", "read"
      ]
    },
    "transport_guid": { "type": ["string", "null"] },
    "attempt_count": { "type": "integer", "minimum": 0 },
    "ambiguous": { "type": "boolean", "default": false },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
