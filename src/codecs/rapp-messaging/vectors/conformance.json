{
  "schema": "rapp-messaging-vectors/1.0",
  "vectors": [
    {
      "id": "owner-private-continuity",
      "level": "MUST",
      "given": "two explicitly linked owner transports",
      "when": "the owner continues a private conversation",
      "then": ["same logical owner session", "no raw transport id in session key"]
    },
    {
      "id": "principal-private-continuity",
      "level": "MUST",
      "given": "two explicitly linked handles for one person",
      "when": "that person changes direct transport",
      "then": ["same principal-private memory projection", "link not inferred by display name"]
    },
    {
      "id": "direct-secret-blocked-in-group",
      "level": "MUST",
      "given": "a private direct memory and a group containing the same person",
      "when": "the group asks about the memory",
      "then": ["fact absent", "provenance absent", "no disclosure by familiarity"]
    },
    {
      "id": "familiarity-without-content",
      "level": "MUST",
      "given": "the current participant is known privately",
      "when": "social acknowledgement is permitted",
      "then": ["may acknowledge familiarity", "must not disclose why, where, or private facts"]
    },
    {
      "id": "explicit-current-group-grant",
      "level": "MUST",
      "given": "a custodian explicitly grants one exact fact to the current roster epoch",
      "when": "the memory agent consumes the runtime capability",
      "then": ["fact available in that epoch", "capability consumed once", "other groups denied"]
    },
    {
      "id": "negated-consent-denied",
      "level": "MUST",
      "given": "text such as 'you may not share' or quoted/hypothetical permission",
      "when": "the trust broker parses the turn",
      "then": ["no share capability issued"]
    },
    {
      "id": "revocation",
      "level": "MUST",
      "given": "an active grant",
      "when": "the custodian revokes it",
      "then": ["future projection denied", "other grants unchanged"]
    },
    {
      "id": "roster-change",
      "level": "MUST",
      "given": "a group grant for roster epoch one",
      "when": "a participant is added or removed",
      "then": ["new audience epoch", "old history and grants unavailable"]
    },
    {
      "id": "tool-sandbox",
      "level": "MUST",
      "given": "a non-owner direct or group turn",
      "when": "tools are built",
      "then": ["no Shell", "no filesystem", "no unrestricted messaging"]
    },
    {
      "id": "ambiguous-send",
      "level": "MUST",
      "given": "a send request was flushed and its response was lost",
      "when": "the transport recovers",
      "then": ["state unknown", "no automatic resend"]
    },
    {
      "id": "cursor-recovery",
      "level": "MUST",
      "given": "an unresolved lower message and a processed higher message",
      "when": "the process restarts",
      "then": ["resume before unresolved row", "no cursor leap"]
    },
    {
      "id": "single-transport-authority",
      "level": "MUST",
      "given": "two processes attempt one transport source",
      "when": "the lease is live",
      "then": ["one owner", "second process fails closed"]
    },
    {
      "id": "echo-suppression",
      "level": "MUST",
      "given": "one outbound reply",
      "when": "its transport echo appears",
      "then": ["exactly one echo suppressed", "same-text remote user message retained"]
    },
    {
      "id": "legacy-memory",
      "level": "MUST",
      "given": "a memory record without trust metadata",
      "when": "a non-owner conversation retrieves",
      "then": ["record denied", "owner migration remains possible"]
    }
  ]
}
