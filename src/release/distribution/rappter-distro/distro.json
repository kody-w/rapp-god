{
  "schema": "rappter-distro-manifest/1.0",
  "name": "rappter-distro",
  "version": "0.1.0",
  "kernel": {
    "grail_repo": "kody-w/rapp-installer",
    "grail_version_min": "0.6.0"
  },
  "layout": {
    "agents":   { "source": "agents/@rappter/", "install_to": "agents/@rappter/" },
    "lib":      { "source": "lib/",             "install_to": "utils/" },
    "organs":   { "source": "organs/",          "install_to": "utils/organs/" },
    "senses":   { "source": "senses/",          "install_to": "utils/senses/" },
    "web":      { "source": "ui/web/",          "install_to": "utils/web/" },
    "index":    { "source": "ui/index.html",    "install_to": "index.html (replaces grail's smaller bundled UI)" },
    "tls":      { "source": "ui/tls_proxy.py",  "install_to": "tls_proxy.py" }
  },
  "stays_in_kernel_mirror": [
    "Tier 1 brainstem (rapp_brainstem/)",
    "Tier 2 Azure Functions (rapp_swarm/ + installer/azuredeploy.json + installer/install-swarm.sh)",
    "Tier 3 Copilot Studio (installer/MSFTAIBASMultiAgentCopilot_*.zip)",
    "Cloudflare Worker auth bridge (worker/)",
    "community_rapp/ (grail-canonical)",
    "docs/, blog.html, release-notes.html, skill.md, deploy.{sh,ps1}, install.command (grail-canonical)"
  ],
  "launcher": {
    "from":   "utils/boot.py",
    "invoke": "python utils/boot.py",
    "rationale": "wraps grail brainstem.py via runpy; monkey-patches Flask.run to install organs/senses before serve"
  },
  "kernel_features_relied_on": [
    "sys.modules shim for utils and utils.azure_file_storage (transparent storage)",
    "agent discovery via agents/*_agent.py (importlib.util.spec_from_file_location)",
    "Flask.run hook in boot.py wrapper (monkey-patched before kernel runs; organs/senses mount onto kernel app)"
  ]
}
