# GitHub token — get yours from: gh auth token
# Or run `gh auth login` first and leave this blank (auto-detected)
GITHUB_TOKEN=

# Model to use (Copilot supports: gpt-4o, gpt-4o-mini, gpt-4.1, o3-mini, claude-3.5-sonnet)
GITHUB_MODEL=gpt-4o

# Point to your private soul and agents (optional — defaults to ./soul.md and ./agents/)
SOUL_PATH=./soul.md
AGENTS_PATH=./agents

# Port (default: 7071)
PORT=7071

# Password for voice.zip (ElevenLabs API key config)
VOICE_ZIP_PASSWORD=

# Optional ArtGenerator agent — authenticate locally with `az login`
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-2
AZURE_OPENAI_IMAGE_API_VERSION=2025-04-01-preview
