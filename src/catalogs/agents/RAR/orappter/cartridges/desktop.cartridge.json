    {"name": "synth", "icon": "♪", "cartridge": "synth.lispy"},
    {"name": "radio", "icon": "◉", "cartridge": "radio.lispy"},
    {"name": "canvas", "icon": "✎", "cartridge": "canvas.lispy"},
    {"name": "school", "icon": "▲", "cartridge": "school.lispy"},
    {"name": "arena", "icon": "⊕", "cartridge": "arena.lispy"},
    {"name": "tamagotchi", "icon": "♥", "cartridge": "tamagotchi.lispy"},
    {"name": "garden", "icon": "❋", "cartridge": "garden.lispy"},
    {"name": "dungeon", "icon": "▼", "cartridge": "dungeon.lispy"},
    {"name": "timecapsule", "icon": "◈", "cartridge": "timecapsule.lispy"},
    {"name": "romloader", "icon": "■", "cartridge": "romloader.lispy"},
    {"name": "cards", "icon": "♠", "cartridge": "rapp_sdk.lispy"},
