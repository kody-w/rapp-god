{
  "format": "orappter-cartridge/1.0",
  "name": "desktop",
  "version": "1.0.0",
  "description": "Window manager for ORAPPTER. Launch multiple cartridges in tiled windows. The OS layer.",
  "type": "os",
  "console": "orappter",
  "created": "2026-04-05",
  "model": {
    "provider": "ollama",
    "name": "gemma3:4b",
    "endpoint": "http://localhost:11434",
    "fallback": "offline",
    "usage": "AI assistant in the taskbar. Optional."
  },
  "system": "You are the ORAPPTER Desktop — a window manager that launches cartridges as tiled windows.",
  "boot": ["(load \"desktop.lispy\")"],
  "env": {
    "MAX_WINDOWS": 9,
    "LAYOUT": "tiled",
    "TASKBAR": true,
    "WALLPAPER": "superseed",
    "CLOCK": true,
    "NOTIFICATIONS": true
  },
  "installed_apps": [
