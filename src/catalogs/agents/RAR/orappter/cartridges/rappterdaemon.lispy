;; ═══════════════════════════════════════════════════════════════
;; RAPPTERDAEMON — The game cartridge for RAPPTERBOY
;; A complete turn-based RPG. Load into RAPPTERBOY.
;; RAPPTERBOY loads into ORAPPTER. Three levels deep.
;;
;; (cartridge-load-file "rappterboy.cartridge.json")
;; (cartridge-load-file "rappterdaemon.cartridge.json")
;; (new-game "Molly" registry)
;; (explore)
;;
;; Gotta Perform 'Em All!
;; ═══════════════════════════════════════════════════════════════

(define _agent_name "rappterdaemon")
(define _agent_desc "Turn-based RPG — AI agent cards as battle daemons. The Pokemon of the agentic era.")

(define GAME_VERSION "1.0.0")


;; ═══════════════════════════════════════════════════════════════
;; SECTION 1: Game State
;; ═══════════════════════════════════════════════════════════════

(define *player* nil)
(define *party* (list))
(define *party-max* 6)
(define *active* nil)
(define *wild* nil)
(define *in-battle* false)
(define *location-idx* 0)
(define *badges* (list))
(define *pokedex* (make-dict))  ;; seen/caught registry
(define *items* (make-dict "potion" 5 "rare-candy" 1 "master-ball" 0))
(define *money* 1000)
(define *steps* 0)
(define *battle-count* 0)


;; ═══════════════════════════════════════════════════════════════
;; SECTION 2: The World Map
;; ═══════════════════════════════════════════════════════════════

(define WORLD
  (list
    (make-dict
      "name" "Pallet Lab"
      "description" "Where every trainer begins. Professor Rapp's laboratory."
      "level-range" (list 1 5)
      "types" (list "core" "devtools")
      "shop" true
      "gym" false
      "encounters" 3)
    (make-dict
      "name" "Sales Route 1"
      "description" "The road between towns. Sales agents roam freely."
      "level-range" (list 3 8)
      "types" (list "b2b_sales" "b2c_sales")
      "shop" false
      "gym" false
      "encounters" 5)
    (make-dict
      "name" "Pipeline City"
      "description" "A bustling city where data flows through every street."
      "level-range" (list 5 12)
      "types" (list "pipeline" "integrations")
      "shop" true
      "gym" true
      "gym-leader" (make-dict
        "name" "Howard"
        "title" "The CardSmith"
        "badge" "Forge Badge"
        "agent" "@borg/borg_agent"
        "level" 15
        "dialogue-before" "Resistance is futile. Your deck will be assimilated."
        "dialogue-after" "Impressive. You've earned the Forge Badge. Now go create."))
    (make-dict
      "name" "Health District"
      "description" "The healing quarter. Care agents patrol the corridors."
      "level-range" (list 8 16)
      "types" (list "healthcare")
      "shop" true
      "gym" false
      "encounters" 4)
    (make-dict
      "name" "Finance Tower"
      "description" "Glass and steel. Every transaction is tracked."
      "level-range" (list 12 20)
      "types" (list "financial_services")
      "shop" true
      "gym" true
      "gym-leader" (make-dict
        "name" "The Auditor"
        "title" "Master of Ledgers"
        "badge" "Ledger Badge"
        "agent" "@aibast-agents-library/fraud-detection-alert"
        "level" 25
        "dialogue-before" "Every transaction tells a story. Show me yours."
        "dialogue-after" "Your books are clean. Take the Ledger Badge."))
    (make-dict
      "name" "Factory Floor"
      "description" "The hum of manufacturing. Optimization agents everywhere."
      "level-range" (list 16 25)
      "types" (list "manufacturing" "energy")
      "shop" true
      "gym" false
      "encounters" 5)
    (make-dict
      "name" "Productivity Peak"
      "description" "The summit. Only the most efficient reach the top."
      "level-range" (list 20 30)
