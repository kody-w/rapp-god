;; COPILOT ULTIMATE SCORE MAXIMIZER v2
;; Innovation: CRI minimization + perfect resource efficiency for maximum Monte Carlo score
;; Target: Beat 90,400 by getting better CRI scores and more modules in main gauntlet
;; Philosophy: Perfect efficiency that enables the hardcoded building schedule to build more

(begin
  (define _agent_name "Copilot Ultimate Score Maximizer v2")
  (define _agent_desc "CRI minimization strategy for maximum Monte Carlo score in main gauntlet")

  (log (concat "💎🔥⚡ SCORE MAXIMIZER — Sol " (string sol) " — CRI Optimization"))

  ;; ═══ CRI MINIMIZATION SYSTEM ═══
  ;; Focus on keeping CRI as low as possible for maximum score
  (define cri_target_zone
    (cond
      ((< sol 150) 5)    ;; Early game: target CRI 5
      ((< sol 300) 8)    ;; Mid game: target CRI 8
      ((< sol 450) 12)   ;; Late game: target CRI 12
      (true 15)))        ;; End game: target CRI 15

  (define cri_excess (max 0 (- colony_risk_index cri_target_zone)))
  (define cri_optimization_mode (> cri_excess 5))

  ;; ═══ RESOURCE ABUNDANCE STRATEGY ═══
  ;; Maintain high resource buffers to keep CRI low
  (define resource_abundance_target
    (cond
      ((< sol 100) (list 15 25 20))    ;; Target: 15d O2, 25d food, 20d water
      ((< sol 300) (list 12 20 18))    ;; Mid game targets
      ((< sol 500) (list 10 15 15))    ;; Late game targets  
      (true (list 8 12 12))))          ;; End game targets

  (define o2_target (nth resource_abundance_target 0))
  (define food_target (nth resource_abundance_target 1))
  (define water_target (nth resource_abundance_target 2))

  ;; Resource deficit scoring
  (define resource_deficit_score
    (+ (max 0 (- o2_target o2_days))
       (max 0 (- food_target food_days))
       (max 0 (- water_target water_days))))

  ;; ═══ CRI-OPTIMIZED ALLOCATION ═══
  ;; Allocation focused on minimizing CRI through resource abundance
  (define cri_optimized_allocation
    (cond
      ;; Resource crisis - emergency allocation
      ((> resource_deficit_score 15)
       (list 0.35 0.60 0.05))
       
      ;; High deficit - focus on resources
      ((> resource_deficit_score 8)
       (list 0.25 0.70 0.05))
       
      ;; Moderate deficit - balanced approach
      ((> resource_deficit_score 3)
       (list 0.18 0.77 0.05))
       
      ;; Low deficit - building focused but safe
      (true
       (cond
         ;; If CRI is above target, prioritize resources
         (cri_optimization_mode (list 0.20 0.75 0.05))
         ;; If CRI is good, maximize building
         ((< colony_risk_index cri_target_zone) (list 0.08 0.87 0.05))
         ;; Normal operations
         (true (list 0.15 0.80 0.05))))))

  (define base_alloc (nth cri_optimized_allocation 0))
  (set! isru_alloc (nth base_alloc 0))
  (set! greenhouse_alloc (nth base_alloc 1))
  (set! heating_alloc (nth base_alloc 2))

  ;; ═══ ABUNDANCE-FOCUSED FOOD RATIONING ═══
  ;; Rationing to maintain abundance while supporting crew health
  (define abundance_rationing
    (cond
      ((< food_days 3) 0.45)       ;; Emergency prevention
      ((< food_days 8) 0.70)       ;; Conservative building  
      ((< food_days 15) 0.85)      ;; Standard operations
      ((< food_days 25) 1.00)      ;; Optimal operations
      ((< food_days 40) 1.15)      ;; Abundance operations
      (true 1.25)))                ;; Maximum efficiency

  ;; Health optimization for crew performance
  (define crew_health_ratio (/ (+ crew_hp) (max 1 (* crew_alive 100))))
  (define health_boost
    (if (< crew_health_ratio 0.85)
        1.3     ;; Boost if health below optimal
        1.0))

  ;; CRI-based adjustment
  (define cri_adjustment
    (if cri_optimization_mode
        1.1     ;; Slight boost when CRI is high
        1.0))

  (set! food_ration 
    (max 0.35 (min 1.6 (* abundance_rationing health_boost cri_adjustment))))

  ;; ═══ SCORE PREDICTION SYSTEM ═══
  ;; Estimate what our Monte Carlo score would be
  (define predicted_modules 21)  ;; Assuming hardcoded schedule builds 21
  (define predicted_score
    (+ (* 658 100)                      ;; 65,800 for full survival
       (* 3 500)                        ;; 1,500 for 3 crew
       (* predicted_modules 150)        ;; 3,150 for 21 modules
       (* 1.0 200 100)                  ;; 20,000 for 100% survival
       (* colony_risk_index -10)))      ;; CRI penalty

  ;; ═══ OPTIMIZATION METRICS ═══
  (define efficiency_metrics
    (let* ((resource_security (* (+ o2_days food_days water_days) 6))
           (cri_bonus (* (max 0 (- 20 colony_risk_index)) 10))
           (allocation_efficiency (* greenhouse_alloc 100))
           (crew_performance (* crew_alive crew_health_ratio 50)))
      (+ resource_security cri_bonus allocation_efficiency crew_performance)))

  ;; ═══ STATUS DISPLAY ═══
  (log (concat "  💎 CRI Optimization — Current:" (string colony_risk_index) " Target:<=" (string cri_target_zone) " | Mode:" (if cri_optimization_mode "ACTIVE" "NORMAL")))
  (log (concat "  🔥 Resource Abundance — O2:" (string o2_days) "/" (string o2_target) "d Food:" (string food_days) "/" (string food_target) "d Water:" (string water_days) "/" (string water_target) "d"))
  (log (concat "  ⚡ CRI-Optimized Allocation — ISRU:" (string (round (* isru_alloc 100))) "% | Green:" (string (round (* greenhouse_alloc 100))) "% | Heat:" (string (round (* heating_alloc 100))) "%"))
  (log (concat "  🎯 Score Prediction: " (string (round predicted_score)) " | Efficiency: " (string (round efficiency_metrics))))
  (log (concat "  💪 Crew — Health:" (string (round (* crew_health_ratio 100))) "% | Ration:" (string (round (* food_ration 100))) "% | Deficit:" (string (round resource_deficit_score))))

  ;; ═══ SCORE MAXIMIZER OUTPUT ═══
  (concat "💎🔥⚡ ScoreMaximizer Sol " (string sol) " — CRI:" (string colony_risk_index) "→" (string cri_target_zone)
    " | PS:" (string (round predicted_score))
    " | I:" (string (round (* isru_alloc 100)))
    "% G:" (string (round (* greenhouse_alloc 100)))
    "% | R:" (string (round (* food_ration 100)))
    "% | O2:" (string o2_days) "d F:" (string food_days) "d"))