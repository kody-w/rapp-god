;; COPILOT ULTIMATE 729-FRAME DESTROYER V1
;; Revolutionary: Optimized specifically for 729-frame gauntlet (vs 602-frame challenge in notes)
;; Goal: Maximize score in extended 729-sol challenge through ultimate precision optimization
;; Features: Sol-30 ultra-early start, 40-sol prediction, perfect efficiency for longer challenge

(begin
  (define _agent_name "Copilot Ultimate 729-Frame Destroyer v1")
  (define _agent_desc "Ultimate optimization for 729-frame extended gauntlet challenge targeting maximum score")

  (log (concat "🌟💫⚡🏆🎯💎🚀 ULTIMATE 729-FRAME DESTROYER — Sol " (string sol) " — Extended Challenge Master"))

  ;; ═══ ULTIMATE 729-FRAME FARMING REVOLUTION ═══
  ;; Breakthrough: Sol-30 start optimized for extended 729-frame challenge
  (define mission_phase_normalized (/ sol 729))
  
  ;; Ultimate farming windows for extended challenge
  (define ultimate_ultra_early_phase (and (>= sol 30) (< sol 95)))        ;; 65-sol ultimate advantage
  (define ultimate_early_phase (and (>= sol 95) (< sol 170)))             ;; Extended early optimization
  (define ultimate_normal_phase (and (>= sol 170) (< sol 280)))           ;; Normal deployment
  (define ultimate_mid_phase (and (>= sol 280) (< sol 420)))              ;; Mid-game optimization
  (define ultimate_late_phase (>= sol 420))                               ;; Extended late-game

  ;; ═══ ULTIMATE CRI PREDICTION ENGINE (40-SOL HORIZON) ═══
  ;; Ultimate: 40-sol horizon optimized for 729-frame challenge complexity
  (define cri_current colony_risk_index)
  (define cri_prediction_horizon 40)  ;; Maximum prediction for extended challenge

  ;; Ultimate CRI growth model calibrated for 729 frames
  (define ultimate_cri_base_rate
    (cond
      ((< sol 60) 0.04)       ;; Ultra-early stability
      ((< sol 140) 0.07)      ;; Early controlled growth  
      ((< sol 250) 0.11)      ;; Mid-early acceleration
      ((< sol 400) 0.16)      ;; Mid-game peak
      ((< sol 550) 0.18)      ;; Late-game crisis
      ((< sol 650) 0.14)      ;; End-game management
      (true 0.06)))           ;; Final stability

  ;; Ultimate repair bay orchestration for extended challenge
  (define ultimate_repair_bay_count (max 1 (round (* modules_built 0.55))))  ;; 55% for 729-frame durability
  (define ultimate_infrastructure_protection 
    (* 1.55 (pow 2.1 (min ultimate_repair_bay_count 10))))

  ;; Ultimate resource prediction for extended margins
  (define ultimate_resource_prediction_factor
    (- 2.6 (+ (max 0 (/ 2.2 (max 1 o2_days)))
              (max 0 (/ 2.8 (max 1 food_days)))
              (max 0 (/ 2.0 (max 1 water_days))))))

  ;; Ultimate threat accumulation for 729-frame modeling
  (define predicted_ultimate_cri_change
    (- ultimate_cri_base_rate                          ;; Base threat for extended challenge
       (/ ultimate_infrastructure_protection 16)       ;; Enhanced repair for durability
       (max 0 ultimate_resource_prediction_factor)))   ;; Extended resource prediction

  ;; 40-sol CRI prediction for 729-frame optimization
  (define predicted_cri_40_sols 
    (max 3 (+ cri_current (* predicted_ultimate_cri_change cri_prediction_horizon))))

  ;; ═══ ULTIMATE 12-TIER THREAT SYSTEM ═══
  ;; Ultimate precision threat response for 729-frame complexity
  (define ultimate_threat_level
    (cond
      ((< predicted_cri_40_sols 6) 0)    ;; Perfect stability
      ((< predicted_cri_40_sols 10) 1)   ;; Minimal threat
      ((< predicted_cri_40_sols 15) 2)   ;; Low threat
      ((< predicted_cri_40_sols 21) 3)   ;; Moderate-low threat
      ((< predicted_cri_40_sols 28) 4)   ;; Moderate threat  
      ((< predicted_cri_40_sols 36) 5)   ;; Moderate-high threat
      ((< predicted_cri_40_sols 45) 6)   ;; High threat
      ((< predicted_cri_40_sols 56) 7)   ;; Critical threat
      ((< predicted_cri_40_sols 68) 8)   ;; Extreme threat
      ((< predicted_cri_40_sols 82) 9)   ;; Maximum threat
      ((< predicted_cri_40_sols 98) 10)  ;; Crisis threat
      (true 11)))                        ;; Ultimate threat

  ;; Ultimate building allocation for 729-frame optimization
  (define ultimate_building_efficiency
    (cond
      ;; Ultimate ultra-early phase (Sol 30-95) - Maximum efficiency for extended challenge
      (ultimate_ultra_early_phase
        (cond
          ((<= ultimate_threat_level 3) 0.9985)  ;; Near-perfect for extended challenge
          ((<= ultimate_threat_level 6) 0.9975)  ;; Ultimate efficiency
          ((<= ultimate_threat_level 9) 0.9950)  ;; Very high efficiency
          (true 0.9920)))                        ;; High efficiency

      ;; Ultimate early phase (Sol 95-170) - Sustained maximum efficiency
      (ultimate_early_phase
        (cond
          ((<= ultimate_threat_level 3) 0.9975)
          ((<= ultimate_threat_level 6) 0.9960)
          ((<= ultimate_threat_level 9) 0.9930)
          (true 0.9890)))

      ;; Ultimate normal phase (Sol 170-280) - Optimized efficiency
      (ultimate_normal_phase
        (cond
          ((<= ultimate_threat_level 4) 0.9950)
          ((<= ultimate_threat_level 7) 0.9920)
          ((<= ultimate_threat_level 10) 0.9870)
          (true 0.9800)))

      ;; Ultimate mid phase (Sol 280-420) - Balanced efficiency
      (ultimate_mid_phase
        (cond
          ((<= ultimate_threat_level 5) 0.9920)
          ((<= ultimate_threat_level 8) 0.9880)
          ((<= ultimate_threat_level 10) 0.9820)
          (true 0.9720)))

      ;; Ultimate late phase (Sol 420+) - Sustained efficiency for extended challenge
      (true
        (cond
          ((<= ultimate_threat_level 6) 0.9890)
          ((<= ultimate_threat_level 9) 0.9840)
          ((<= ultimate_threat_level 11) 0.9760)
          (true 0.9650)))))

  ;; Ultimate resource allocation with micro-margins for 729 frames
  (define ultimate_base_isru_alloc 
    (- 1.0 ultimate_building_efficiency
       (* 0.45 (max 0 (- 1.0 (/ o2_days 0.8))))))   ;; 0.8-day O2 margin (ultimate)

  (define ultimate_base_greenhouse_alloc
    (- 1.0 ultimate_building_efficiency ultimate_base_isru_alloc
       (* 0.35 (max 0 (- 1.0 (/ food_days 0.9))))))  ;; 0.9-day food margin (ultimate)

  (define ultimate_base_heating_alloc
    (- 1.0 ultimate_building_efficiency ultimate_base_isru_alloc ultimate_base_greenhouse_alloc))

  ;; Apply ultimate allocation with extended challenge bounds
  (set! isru_alloc (max 0.03 (min 0.80 ultimate_base_isru_alloc)))
  (set! greenhouse_alloc (max 0.03 (min 0.75 ultimate_base_greenhouse_alloc)))
  (set! heating_alloc (max 0.06 (min 0.94 ultimate_base_heating_alloc)))

  ;; ═══ ULTIMATE BUILDING ALLOCATION ═══
  (set! building_alloc ultimate_building_efficiency)

  ;; ═══ ULTIMATE NUTRITION FOR EXTENDED CHALLENGE ═══
  ;; Ultimate health + CRI + farming for 729-frame optimization
  (define ultimate_health_factor (/ (apply + (map (lambda (c) c.h) crew)) (max 1 (* (length crew) 100))))
  (define ultimate_cri_factor (max 0.20 (- 1.0 (/ cri_current 90))))
  (define ultimate_farming_multiplier 
    (cond
      (ultimate_ultra_early_phase 5.5)   ;; Maximum boost for extended challenge
      (ultimate_early_phase 4.9)         ;; Ultimate boost
      (ultimate_normal_phase 4.2)        ;; High boost
      (ultimate_mid_phase 3.6)           ;; Good boost
      (true 3.0)))                       ;; Sustained boost

  (define ultimate_nutrition_target 
    (* ultimate_health_factor ultimate_cri_factor ultimate_farming_multiplier))

  ;; Ultimate food rationing for 729-frame precision
  (define ultimate_food_ration
    (cond
      ;; Ultimate micro-margin strategy for extended challenge
      ((< food_days 0.7) 0.22)           ;; Ultimate emergency
      ((< food_days 1.0) 0.28)           ;; Maximum emergency  
      ((< food_days 1.4) 0.36)           ;; Critical rationing
      ((< food_days 2.2) 0.48)           ;; Heavy rationing
      ((< food_days 3.8) 0.64)           ;; Conservative rationing
      (true (min 0.99 ultimate_nutrition_target))))  ;; Ultimate nutrition for modules

  (set! food_ration ultimate_food_ration)

  ;; ═══ ULTIMATE DIAGNOSTIC OUTPUT ═══
  (log (concat "  🌟 Ultimate Phase: " 
    (if ultimate_ultra_early_phase "ULTRA-EARLY-ULTIMATE"
    (if ultimate_early_phase "EARLY-ULTIMATE" 
    (if ultimate_normal_phase "NORMAL-ULTIMATE" 
    (if ultimate_mid_phase "MID-ULTIMATE" "LATE-ULTIMATE"))))))

  (log (concat "  ⚡ Threat Level: " (string ultimate_threat_level) "/11 | Predicted CRI(40): " (string (round predicted_cri_40_sols))))
  (log (concat "  🏭 Build Efficiency: " (string (round (* ultimate_building_efficiency 100000))) "/100000 | Repair Bays: " (string ultimate_repair_bay_count)))
  (log (concat "  🎯 Allocation — I:" (string (round (* isru_alloc 100))) "% G:" (string (round (* greenhouse_alloc 100))) "% H:" (string (round (* heating_alloc 100))) "% B:" (string (round (* building_alloc 1000))) "/1000"))
  (log (concat "  💎 Nutrition: " (string (round (* ultimate_nutrition_target 100))) "% | Ration: " (string (round (* food_ration 100))) "% | Margins: O2=" (string o2_days) "d F=" (string food_days) "d"))

  ;; ═══ ULTIMATE OUTPUT SUMMARY ═══
  (concat "Ultimate729 Sol " (string sol) " — Extended Challenge Master"
    " | TL:" (string ultimate_threat_level) "/11"
    " | BE:" (string (round (* building_alloc 10000))) "/10000"
    " | I:" (string (round (* isru_alloc 100)))
    "% G:" (string (round (* greenhouse_alloc 100)))
    "% H:" (string (round (* heating_alloc 100)))
    "% | R:" (string (round (* food_ration 100)))
    "% | O2:" (string o2_days)
    "d F:" (string food_days) "d"))