;; COPILOT CRI OPTIMIZATION MASTER v1
;; Target: Beat 109,840 by reducing P75 CRI from 36 to <30 for +60+ points
;; Strategy: Perfect resource management to minimize Colony Risk Index
;; Keep existing survival foundation, optimize CRI control

(begin
  (define _agent_name "Copilot CRI Optimization Master v1")
  (define _agent_desc "Precision CRI control for 110,000+ score breakthrough")
  
  (log (concat "💎📊⚡ CRI MASTER — Sol " (string sol) " — CRI:" (string colony_risk_index) " — MinHP:" (string crew_min_hp) " — Crew:" (string crew_count)))
  
  ;; ═══ CRI OPTIMIZATION TARGET ═══ 
  ;; Current: P75 CRI = 36 (penalty: -360)
  ;; Target:  P75 CRI = 25 (penalty: -250) = +110 points
  ;; Goal score: 109,840 + 110 = 109,950+

  ;; ═══ ENHANCED CREW HEALTH THRESHOLDS ═══
  (define crew_excellent (>= crew_min_hp 85))             ;; Excellent - maintain efficiency
  (define crew_very_good (>= crew_min_hp 75))             ;; Very good - light boost
  (define crew_good (>= crew_min_hp 65))                  ;; Good - moderate intervention
  (define crew_concerning (>= crew_min_hp 55))            ;; Concerning - enhanced response
  (define crew_serious (>= crew_min_hp 45))               ;; Serious - high response
  (define crew_critical (>= crew_min_hp 35))              ;; Critical - maximum response
  (define crew_emergency (>= crew_min_hp 25))             ;; Emergency - override protocols
  (define crew_death_imminent (< crew_min_hp 25))         ;; Death imminent - survival mode

  ;; Crew count management
  (define current_crew_count crew_count)
  (define target_achieved (>= current_crew_count 4))      ;; Maintain 4+ crew
  (define target_backup (>= current_crew_count 3))        ;; Backup target

  ;; ═══ PHASE AND HAZARD DETECTION ═══
  (define early_phase (< sol 200))                        ;; Foundation phase
  (define mid_phase (and (>= sol 200) (< sol 500)))       ;; Security phase  
  (define late_phase (and (>= sol 500) (< sol 700)))      ;; Optimization phase
  (define v6_prep (and (>= sol 700) (< sol 778)))         ;; V6 preparation
  (define v6_active (and (>= sol 778) (< sol 847)))       ;; V6 active period
  (define endgame (>= sol 847))                           ;; Final phase

  ;; ═══ CRI CONTROL SYSTEM ═══
  ;; Aggressive CRI reduction targets by phase
  (define cri_target
    (cond
      (v6_active 20)                    ;; V6: Ultra-low CRI target
      (v6_prep 18)                      ;; V6 prep: Very low CRI
      (late_phase 15)                   ;; Late: Low CRI target
      (mid_phase 12)                    ;; Mid: Very low CRI
      (early_phase 10)                  ;; Early: Minimal CRI
      (true 20)))                       ;; Default

  ;; CRI emergency detection
  (define cri_emergency (> colony_risk_index (* cri_target 2.0)))
  (define cri_high (> colony_risk_index (* cri_target 1.5)))
  (define cri_elevated (> colony_risk_index cri_target))

  ;; ═══ ENHANCED RESOURCE BUFFER TARGETS ═══
  ;; Higher buffers = lower CRI
  (define power_target
    (cond
      (v6_active 700)                   ;; V6: Ultra-high power buffer
      (v6_prep 650)                     ;; V6 prep: High power buffer
      (late_phase 600)                  ;; Late: High buffer
      (mid_phase 550)                   ;; Mid: Enhanced buffer
      (early_phase 500)                 ;; Early: Strong buffer
      (true 600)))

  (define o2_target_days
    (cond
      (cri_emergency 25.0)              ;; CRI emergency: maximum buffer
      (cri_high 20.0)                   ;; CRI high: high buffer  
      (cri_elevated 18.0)               ;; CRI elevated: enhanced buffer
      (v6_active 16.0)                  ;; V6: strong buffer
      (true 15.0)))                     ;; Standard: good buffer

  (define h2o_target_days
    (cond
      (cri_emergency 30.0)              ;; CRI emergency: maximum buffer
      (cri_high 25.0)                   ;; CRI high: high buffer
      (cri_elevated 22.0)               ;; CRI elevated: enhanced buffer
      (v6_active 20.0)                  ;; V6: strong buffer
      (true 18.0)))                     ;; Standard: good buffer

  (define food_target_days
    (cond
      (cri_emergency 35.0)              ;; CRI emergency: maximum buffer
      (cri_high 30.0)                   ;; CRI high: high buffer
      (cri_elevated 28.0)               ;; CRI elevated: enhanced buffer
      (v6_active 25.0)                  ;; V6: strong buffer
      (true 22.0)))                     ;; Standard: good buffer

  ;; ═══ OPTIMIZED REPAIR SCALING ═══
  ;; Conservative repair to preserve power for CRI management
  (define base_repair_multiplier
    (cond
      (crew_death_imminent 12.0)        ;; Death imminent: high but not excessive
      ((not crew_emergency) 10.0)       ;; Emergency: high response
      ((not crew_critical) 8.0)         ;; Critical: moderate-high
      ((not crew_serious) 6.0)          ;; Serious: moderate
      ((not crew_concerning) 4.0)       ;; Concerning: light-moderate
      (crew_excellent 3.0)              ;; Excellent: maintenance
      (true 3.5)))                      ;; Default: moderate

  ;; V6 multiplier (moderate)
  (define v6_repair_multiplier
    (cond
      (v6_active 1.8)                   ;; V6: moderate boost
      (v6_prep 1.5)                     ;; V6 prep: light boost
      (true 1.0)))                      ;; Standard

  (define optimal_repair (* base_repair_multiplier v6_repair_multiplier))

  ;; ═══ CRI-OPTIMIZED ALLOCATION STRATEGY ═══
  ;; Focus on building resource buffers to minimize CRI

  ;; Heating allocation: Balance crew health with power conservation
  (define base_heating_need
    (cond
      (crew_death_imminent 0.80)        ;; Death imminent: high heating
      ((not crew_emergency) 0.70)       ;; Emergency: high heating
      ((not crew_critical) 0.60)        ;; Critical: moderate-high heating
      (cri_emergency 0.55)              ;; CRI emergency: moderate heating
      ((< power power_target) 0.50)     ;; Power building: moderate heating
      (target_achieved 0.45)            ;; Target achieved: efficient heating
      (true 0.50)))                     ;; Default

  ;; Thermal protection (conservative)
  (define thermal_protection
    (cond
      (v6_active 0.12)                  ;; V6: significant protection
      (v6_prep 0.08)                    ;; V6 prep: moderate protection
      (crew_death_imminent 0.06)        ;; Emergency: enhanced protection
      (true 0.04)))                     ;; Standard protection

  (define total_heating (+ base_heating_need thermal_protection))

  ;; ISRU allocation: Prioritize resource security for CRI reduction
  (define isru_need
    (cond
      ((< o2_days 6.0) 0.70)            ;; O2 critical: maximum ISRU
      ((< h2o_days 8.0) 0.65)           ;; H2O critical: high ISRU
      ((< o2_days o2_target_days) 0.55) ;; O2 building: enhanced ISRU
      ((< h2o_days h2o_target_days) 0.50) ;; H2O building: moderate ISRU
      (cri_elevated 0.45)               ;; CRI elevated: resource focus
      (target_achieved 0.35)            ;; Target achieved: maintenance
      (true 0.40)))                     ;; Default

  ;; Greenhouse allocation: Food security for CRI management  
  (define greenhouse_need
    (cond
      ((< food_days 10.0) 0.25)         ;; Food critical: high greenhouse
      ((< food_days food_target_days) 0.20) ;; Food building: moderate greenhouse
      (cri_elevated 0.18)               ;; CRI elevated: food security
      (target_achieved 0.12)            ;; Target achieved: maintenance
      (true 0.15)))                     ;; Default

  ;; ═══ EVENT AND CRI RESPONSE SYSTEM ═══
  (define event_count (length events))
  (define event_response
    (cond
      ((and v6_active (>= event_count 3)) 2.2) ;; V6 + many events: high response
      ((and cri_emergency (>= event_count 2)) 2.0) ;; CRI emergency + events
      ((>= event_count 4) 1.8)                 ;; Many events: high response
      ((>= event_count 3) 1.5)                 ;; Several events: moderate response
      ((>= event_count 2) 1.3)                 ;; Couple events: light response
      ((>= event_count 1) 1.1)                 ;; Single event: minor response
      (true 1.0)))                             ;; No events: baseline

  ;; CRI response: Direct allocation boost for CRI control
  (define cri_response
    (cond
      (cri_emergency 2.0)               ;; CRI emergency: maximum response
      (cri_high 1.6)                    ;; CRI high: high response
      (cri_elevated 1.3)                ;; CRI elevated: moderate response
      (true 1.0)))                      ;; CRI target: baseline

  ;; ═══ FINAL ALLOCATION CALCULATION ═══
  (define calc_heating (* total_heating event_response))
  (define calc_isru (* isru_need event_response cri_response))
  (define calc_greenhouse (* greenhouse_need event_response cri_response))

  ;; Normalize allocations
  (define total_calc (+ calc_heating calc_isru calc_greenhouse))
  (define norm_factor (/ 1.0 total_calc))

  (define final_heating (* calc_heating norm_factor))
  (define final_isru (* calc_isru norm_factor))
  (define final_greenhouse (* calc_greenhouse norm_factor))

  ;; ═══ EMERGENCY OVERRIDE PROTOCOLS ═══
  (cond
    ;; DEATH IMMINENT: Maximum crew preservation
    (crew_death_imminent
     (set! heating_alloc 0.88)
     (set! isru_alloc 0.10)
     (set! greenhouse_alloc 0.02)
     (set! building_alloc 0.0)
     (log "🚨💀 DEATH CRISIS: Maximum preservation"))
    
    ;; CRI EMERGENCY: Resource security priority
    (cri_emergency
     (set! heating_alloc 0.65)
     (set! isru_alloc 0.30)
     (set! greenhouse_alloc 0.05)
     (set! building_alloc 0.0)
     (log "🚨📊 CRI EMERGENCY: Resource security focus"))
    
    ;; EMERGENCY: High preservation
    ((not crew_emergency)
     (set! heating_alloc 0.80)
     (set! isru_alloc 0.16)
     (set! greenhouse_alloc 0.04)
     (set! building_alloc 0.0)
     (log "🚨🔥 EMERGENCY: High preservation"))
    
    ;; NORMAL: CRI-optimized allocation
    (true
     (set! heating_alloc (max 0.35 (min 0.80 final_heating)))
     (set! isru_alloc (max 0.10 (min 0.55 final_isru)))
     (set! greenhouse_alloc (max 0.05 (min 0.35 final_greenhouse)))
     (set! building_alloc 0.0)))

  ;; Apply optimized repair allocation
  (set! repair_alloc optimal_repair)

  ;; ═══ STATUS MONITORING ═══
  (define crew_status
    (if target_achieved "🏆 TARGET(4+)"
    (if target_backup "⚡ BACKUP(3+)"
    "⚠️ MINIMUM")))

  (define health_status
    (if crew_excellent "EXCELLENT"
    (if crew_very_good "VERY_GOOD"
    (if crew_good "GOOD"
    (if crew_concerning "CONCERNING"
    (if crew_serious "SERIOUS"
    (if crew_critical "CRITICAL"
    (if crew_emergency "EMERGENCY" "DEATH_IMMINENT"))))))))

  (define cri_status
    (if cri_emergency "🚨 EMERGENCY"
    (if cri_high "⚠️ HIGH"
    (if cri_elevated "📈 ELEVATED"
    "✅ TARGET"))))

  ;; ═══ COMPREHENSIVE LOGGING ═══
  (log (concat "  🛡️ Crew: " (string current_crew_count) " | MinHP:" (string crew_min_hp) " | " health_status))
  (log (concat "  📊 CRI: " (string colony_risk_index) "/" (string cri_target) " | " cri_status " | Events:" (string event_count)))
  (log (concat "  ⚡ Power: " (string (round power)) "/" (string power_target) " | O2:" (string (round o2_days 1)) "d | H2O:" (string (round h2o_days 1)) "d"))
  (log (concat "  📈 Alloc: H:" (string (round (* heating_alloc 100))) "% I:" (string (round (* isru_alloc 100))) "% G:" (string (round (* greenhouse_alloc 100))) "% R:" (string (round optimal_repair 1)) "x"))

  ;; ═══ SCORE PROJECTION ═══
  (if (> sol 400)
    (let ((proj_crew (if target_achieved 4 current_crew_count))
          (proj_cri (if (< colony_risk_index 30) colony_risk_index 30))
          (proj_score (+ 87000 (* proj_crew 500) 1200 20000 (* proj_cri -10))))
      (log (concat "  🎯 PROJECTION: " (string proj_score) " | Current: 109,840 | Target: 110,000+"))))

  ;; ═══ CRI MASTER OUTPUT ═══
  (concat "CRI-MASTER Sol " (string sol)
    " | " (string current_crew_count) "/" health_status
    " | " crew_status
    " | CRI:" (string colony_risk_index) "/" (string cri_target) " " cri_status
    " | TARGET: 110,000+"))