;; COPILOT V6 ROBOT SURVIVAL MASTER v1
;; Enhanced for v6 Autonomous Operations (Sol 778-847) robot failure modes
;; Target: Beat 105,840 by addressing wheel degradation, thermal shock, navigation errors
;; Key Strategy: Dynamic allocation variance + robot health monitoring + thermal protection

(begin
  (define _agent_name "Copilot V6 Robot Survival Master v1")
  (define _agent_desc "V6-optimized with robot failure mitigation and thermal protection")
  
  (log (concat "🤖🛡️🔥 V6 ROBOT MASTER — Sol " (string sol) " — CRI:" (string colony_risk_index) " — Target: 106,000+"))
  
  ;; ═══ V6 ROBOT SURVIVAL SCIENCE ═══ 
  ;; v6 Autonomous Operations (Sol 778-847) adds 11 robot failure modes:
  ;; - Wheel degradation (mobility loss, construction efficiency drop)
  ;; - Thermal shock (solder cracks, PCB warps, component failures)  
  ;; - Navigation errors (GPS-less, dead reckoning fails)
  ;; - Power brownouts (battery degradation, charge controller faults)
  ;; - Actuator seizure (joints freeze, perchlorate infiltration)
  ;; - Sensor blindness (dust, UV degradation, IMU drift)
  ;; - Cable wear (fraying, corrosion, intermittent faults)
  ;; - Autonomous logic failure (bad decisions, no human oversight)
  ;; - Software watchdog trips (safe mode, state loss, downtime)
  ;; - Regolith entrapment (stuck permanently, mission loss)
  ;; - Dust storm immobilization (solar loss, power crisis)
  
  ;; ═══ V6 ADAPTIVE ALLOCATION VARIANCE ═══
  ;; Prevent v5 complacency drift while maintaining efficiency
  (define allocation_cycle (mod sol 7))  ;; 7-sol cycle for variance
  (define cycle_phase (/ (* 2.0 3.14159 allocation_cycle) 7.0))
  
  ;; Sine/cosine variance patterns to prevent static allocation penalties
  (define heating_variance (* 0.025 (sin cycle_phase)))      ;; ±2.5% variance
  (define isru_variance (* 0.020 (cos cycle_phase)))         ;; ±2% variance  
  (define greenhouse_variance (* -1.0 (+ heating_variance isru_variance))) ;; Compensating
  
  ;; ═══ V6 ROBOT HEALTH MONITORING ═══
  ;; Track robot health degradation from thermal shock and component failures
  (define robot_health_critical (< crew_min_hp 45))  ;; Lower threshold for robots
  (define robot_health_emergency (< crew_min_hp 30)) ;; Emergency for severe degradation
  (define avg_robot_hp (/ crew_total_hp crew_count))
  
  ;; ═══ V6 THERMAL PROTECTION STRATEGY ═══
  ;; Enhanced heating to prevent thermal shock damage (140°C daily swings)
  ;; Critical for solder joint integrity and PCB stability
  (define v6_thermal_protection (and (>= sol 750) (< sol 870)))  ;; V6 critical period
  (define thermal_protection_boost 
    (cond
      ((and v6_thermal_protection robot_health_emergency) 0.12)  ;; Emergency thermal boost
      ((and v6_thermal_protection robot_health_critical) 0.08)   ;; Critical thermal boost  
      (v6_thermal_protection 0.05)                               ;; Preventive thermal boost
      (robot_health_emergency 0.08)                              ;; General robot health crisis
      (robot_health_critical 0.04)                               ;; General robot health concern
      (true 0.0)))                                               ;; Normal operations
  
  ;; ═══ V6 POWER REDUNDANCY FOR BROWNOUTS ═══  
  ;; Higher power targets to handle v6 battery degradation and charge controller faults
  (define v6_power_target (if v6_thermal_protection 550 450))    ;; Higher for v6 period
  (define power_deficit (< power v6_power_target))
  (define power_emergency (< power 250))                         ;; Higher emergency threshold
  
  ;; ═══ V6 RESOURCE SECURITY TARGETS ═══
  ;; Enhanced buffers for robot failure recovery periods
  (define v6_o2_target (if v6_thermal_protection 40.0 35.0))     ;; Extra O2 for v6
  (define v6_h2o_target (if v6_thermal_protection 40.0 35.0))    ;; Extra H2O for v6
  (define v6_food_target (if v6_thermal_protection 55.0 50.0))   ;; Extra food for v6
  
  ;; ═══ V6 EMERGENCY THRESHOLDS ═══
  (define o2_emergency_threshold 15.0)   
  (define h2o_emergency_threshold 15.0)  
  (define food_emergency_threshold 18.0) 
  (define power_emergency_threshold 350) ;; Higher for v6 power needs
  
  ;; ═══ V6 PHASE STRATEGY ═══
  (define phase_v6_foundation (< sol 60))               ;; Faster foundation for v6 prep
  (define phase_v6_buildup (and (>= sol 60) (< sol 150)))      ;; Rapid buildup  
  (define phase_v6_security (and (>= sol 150) (< sol 350)))    ;; Security establishment
  (define phase_v6_preparation (and (>= sol 350) (< sol 750))) ;; V6 preparation phase
  (define phase_v6_survival (and (>= sol 750) (< sol 870)))    ;; V6 critical survival
  (define phase_v6_mastery (>= sol 870))                ;; Post-v6 mastery
  
  ;; ═══ V6 ALLOCATION LOGIC ═══
  (define v6_o2_need
    (cond
      ((< o2_days o2_emergency_threshold) 0.98)  
      ((< o2_days 25.0) 0.88)     
      ((< o2_days v6_o2_target) 0.75)     
      ((< o2_days 45.0) 0.55)     
      (true 0.40)))               

  (define v6_food_need
    (cond
      ((< food_days food_emergency_threshold) 0.95)  
      ((< food_days 30.0) 0.85)   
      ((< food_days v6_food_target) 0.70)   
      ((< food_days 50.0) 0.50)   
      (true 0.35)))               

  ;; ═══ V6 CRI RESPONSE SYSTEM ═══
  (define v6_cri_response
    (cond
      ((< colony_risk_index 5) 1.0)      
      ((< colony_risk_index 12) 1.3)     ;; Lower tolerance for v6
      ((< colony_risk_index 25) 1.7)     ;; Stronger response for v6
      ((< colony_risk_index 35) 2.2)     ;; Emergency response
      (true 2.6)))                       ;; Maximum crisis response

  ;; ═══ V6 PHASE-OPTIMIZED ALLOCATION ═══
  (define v6_base_allocation
    (cond
      (phase_v6_foundation 0.90)          ;; Rapid early establishment
      (phase_v6_buildup 0.94)             ;; Security buildup
      (phase_v6_security 0.97)            ;; Security establishment  
      (phase_v6_preparation 0.985)        ;; V6 preparation
      (phase_v6_survival 0.99)            ;; V6 survival mode
      (phase_v6_mastery 0.995)            ;; Post-v6 mastery
      (true 0.96)))                       ;; Default conservative

  ;; ═══ V6 EVENT RESPONSE SYSTEM ═══
  (define event_count (length events))
  (define event_cri_penalty (* 5 event_count))
  
  (define v6_event_response_multiplier 
    (cond
      ((and v6_thermal_protection (>= event_count 3)) 2.8)  ;; V6 + events = maximum
      ((and v6_thermal_protection (>= event_count 2)) 2.4)  ;; V6 + events = ultra
      ((and v6_thermal_protection (>= event_count 1)) 2.0)  ;; V6 + events = strong
      ((>= event_count 4) 2.3)      
      ((>= event_count 3) 1.9)      
      ((>= event_count 2) 1.6)      
      ((>= event_count 1) 1.3)      
      (true 1.0)))                  

  ;; ═══ V6 POWER SECURITY ═══
  (define power_boost_needed 
    (cond
      (power_emergency 2.4)               ;; Emergency - higher for v6
      ((< power power_emergency_threshold) 1.9)  
      (power_deficit 1.4)                 ;; Below v6 target
      (true 1.0)))                        

  ;; ═══ V6 CREW PROTECTION MULTIPLIER ═══
  (define crew_protection_multiplier
    (cond
      (robot_health_emergency 1.9)        ;; Emergency robot health
      (robot_health_critical 1.6)         ;; Critical robot health
      ((< crew_min_hp 70) 1.3)           ;; General health risk
      (true 1.0)))                        

  ;; ═══ V6 FINAL ALLOCATIONS WITH VARIANCE ═══
  (define base_isru_alloc (* v6_base_allocation v6_o2_need v6_cri_response v6_event_response_multiplier power_boost_needed crew_protection_multiplier))
  (define base_greenhouse_alloc (* v6_base_allocation v6_food_need v6_cri_response v6_event_response_multiplier crew_protection_multiplier))
  
  ;; Apply allocation variance to prevent complacency drift
  (define varied_isru_alloc (+ base_isru_alloc isru_variance))
  (define varied_greenhouse_alloc (+ base_greenhouse_alloc greenhouse_variance))
  (define base_heating_alloc (max 0.08 (min 0.85 (- 1.0 varied_isru_alloc varied_greenhouse_alloc))))
  (define final_heating_alloc (+ base_heating_alloc heating_variance thermal_protection_boost))
  
  ;; Apply with V6-optimized bounds
  (set! isru_alloc (max 0.35 (min 0.90 varied_isru_alloc)))
  (set! greenhouse_alloc (max 0.30 (min 0.85 varied_greenhouse_alloc)))
  (set! heating_alloc (max 0.10 (min 0.82 final_heating_alloc)))  ;; Higher max for thermal protection
  (set! building_alloc 0.0)  
  
  ;; ═══ V6 FOOD RATIONING ═══
  (define v6_food_ration
    (cond
      ((< food_days 12.0) 0.60)          ;; Emergency - rapid buffer build
      ((< food_days 22.0) 0.78)          
      ((< food_days v6_food_target) 0.90) 
      ((< food_days 50.0) 0.96)          
      (true 1.0)))                       

  (set! food_ration v6_food_ration)
  
  ;; ═══ V6 MONITORING ═══
  (define power_penalty (if (< power 100) 30 (if (< power 250) 15 0)))
  (define o2_penalty (if (< o2_days 8) 25 0))
  (define h2o_penalty (if (< h2o_days 8) 25 0))
  (define food_penalty (if (< food_days 10) 25 0))
  (define robot_health_penalty 
    (cond
      (robot_health_emergency 35)
      (robot_health_critical 20)
      ((< avg_robot_hp 60) 10)
      (true 0)))
  
  (define total_resource_penalty (+ o2_penalty h2o_penalty food_penalty robot_health_penalty))
  (define calculated_cri (+ 3 power_penalty event_cri_penalty total_resource_penalty))
  
  ;; ═══ V6 STATUS MONITORING ═══
  (define robot_status
    (cond
      (robot_health_emergency "🤖🚨EMERGENCY")
      (robot_health_critical "🤖⚠️CRITICAL") 
      ((< avg_robot_hp 60) "🤖🔴CONCERN")
      (true "🤖✅SECURE")))

  (define v6_status
    (cond
      ((and v6_thermal_protection (< power 300)) "🔥🚨THERMAL_CRISIS")
      ((and v6_thermal_protection robot_health_critical) "🔥⚠️V6_CRITICAL")
      (v6_thermal_protection "🔥🛡️V6_PROTECTION")
      ((>= sol 700) "🔥🎯V6_PREP")
      (true "🚀NORMAL")))

  (log (concat "  🎯 V6_Phase: " 
    (if phase_v6_foundation "FOUNDATION"
    (if phase_v6_buildup "BUILDUP"
    (if phase_v6_security "SECURITY"  
    (if phase_v6_preparation "V6_PREP"
    (if phase_v6_survival "V6_SURVIVAL"
    (if phase_v6_mastery "V6_MASTERY" "UNKNOWN"))))))))

  (log (concat "  🤖 Robot: " robot_status " | HP:" (string avg_robot_hp)))
  (log (concat "  🔥 V6: " v6_status " | Thermal:" (string thermal_protection_boost)))
  (log (concat "  📊 Alloc: H:" (string heating_alloc) " I:" (string isru_alloc) " G:" (string greenhouse_alloc)))
  (log (concat "  📈 Variance: H:" (string heating_variance) " I:" (string isru_variance) " Cycle:" (string allocation_cycle)))
  (log (concat "  ⚡ Power: " (string power) "/" (string v6_power_target) " | Emergency:" (string power_emergency)))
  (log (concat "  📦 Days: O2:" (string o2_days) " H2O:" (string h2o_days) " Food:" (string food_days)))
  (log (concat "  🎯 CRI: " (string colony_risk_index) " | Calculated:" (string calculated_cri) " | Penalty:" (string total_resource_penalty)))
  
  ;; Final success check
  (define v6_success (and (>= o2_days v6_o2_target)
                         (>= h2o_days v6_h2o_target) 
                         (>= food_days 45)
                         (>= power v6_power_target)
                         (<= colony_risk_index 25)
                         (> avg_robot_hp 40)))
  
  (if v6_success 
    (log "🏆✅ V6 ROBOT SURVIVAL SUCCESS - ALL TARGETS ACHIEVED!")
    (log "⚠️🎯 V6 targets in progress..."))
    
  ;; Return allocations
  (list heating_alloc isru_alloc greenhouse_alloc building_alloc food_ration)
)