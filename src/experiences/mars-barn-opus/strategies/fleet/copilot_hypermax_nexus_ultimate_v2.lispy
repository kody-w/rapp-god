;; COPILOT HYPERMAX NEXUS ULTIMATE v2
;; Innovation: Next-generation adaptive strategy with hyperintelligent optimization
;; Goal: Achieve 700+ sol survival with perfect efficiency and maximum score
;; Features: Multi-dimensional intelligence, predictive compound threat modeling, revolutionary infrastructure orchestration

(begin
  (define _agent_name "Copilot Hypermax Nexus Ultimate v2")
  (define _agent_desc "Next-generation adaptive strategy with hyperintelligent optimization and predictive threat mastery")

  (log (concat "🌌🧠⚡🎯🔮 HYPERMAX NEXUS v2 — Sol " (string sol) " — Hyperintelligent Protocol"))

  ;; ═══ HYPERINTELLIGENT MISSION PHASE ANALYSIS ═══
  ;; Ultra-refined 9-phase mission evolution with adaptive thresholds
  (define genesis_phase (< sol 18))                    ;; Ultra-fast bootstrap
  (define acceleration_phase (and (>= sol 18) (< sol 45)))     ;; Rapid acceleration 
  (define expansion_phase (and (>= sol 45) (< sol 85)))        ;; Strategic expansion
  (define fortification_phase (and (>= sol 85) (< sol 140)))   ;; Infrastructure hardening
  (define optimization_phase (and (>= sol 140) (< sol 220)))   ;; Performance optimization
  (define mastery_phase (and (>= sol 220) (< sol 320)))        ;; System mastery
  (define perfection_phase (and (>= sol 320) (< sol 450)))     ;; Operational perfection
  (define transcendence_phase (and (>= sol 450) (< sol 600)))  ;; Ultimate transcendence
  (define infinity_phase (>= sol 600))                 ;; Beyond limits

  ;; ═══ QUANTUM THREAT MODELING SYSTEM ═══
  ;; Revolutionary 10-level threat analysis with predictive intelligence
  (define threat_perfect (< cri 2))                    ;; Perfect conditions
  (define threat_optimal (and (>= cri 2) (< cri 5)))   ;; Optimal operations
  (define threat_minimal (and (>= cri 5) (< cri 10)))  ;; Minimal vigilance
  (define threat_low (and (>= cri 10) (< cri 18)))     ;; Low concern
  (define threat_moderate (and (>= cri 18) (< cri 30))) ;; Moderate attention
  (define threat_elevated (and (>= cri 30) (< cri 45))) ;; Elevated response
  (define threat_critical (and (>= cri 45) (< cri 65))) ;; Critical measures
  (define threat_severe (and (>= cri 65) (< cri 82)))  ;; Severe protocols
  (define threat_apocalyptic (and (>= cri 82) (< cri 95))) ;; Apocalyptic response
  (define threat_extinction (>= cri 95))               ;; Extinction-level threat

  ;; Multi-dimensional infrastructure vulnerability analysis
  (define infrastructure_health_score
    (* (+ ie se 
          (* repair_count 0.1) 
          (* solar_count 0.08) 
          (* greenhouse_count 0.06)) 
       0.5))

  (define resource_security_score
    (* (+ (min 1.0 (/ o2_days 10))
          (min 1.0 (/ food_days 15))
          (min 1.0 power_ratio)) 
       0.33))

  (define crew_vitality_score
    (* (/ (+ crew_1_health crew_2_health (if (> crew_count 2) crew_3_health 100)) 
          (* crew_count 100)) 
       1.0))

  ;; Hyperintelligent compound threat multiplier
  (define hyperintelligent_threat_multiplier
    (cond
      ((< infrastructure_health_score 0.3) 2.2)
      ((< infrastructure_health_score 0.5) 1.8)
      ((< infrastructure_health_score 0.7) 1.4)
      ((< resource_security_score 0.4) 1.6)
      ((< crew_vitality_score 0.6) 1.3)
      (true 1.0)))

  ;; Predictive threat modeling with temporal analysis
  (define temporal_risk_factor
    (cond
      ((and (> sol 200) (< repair_count 3)) 1.5)
      ((and (> sol 350) (< repair_count 5)) 1.8)
      ((and (> sol 500) (< repair_count 7)) 2.0)
      (true 1.0)))

  (define hypermax_effective_cri 
    (* cri hyperintelligent_threat_multiplier temporal_risk_factor))

  ;; Neural network-inspired threat weight calculation
  (define neural_threat_weight
    (+ (* hypermax_effective_cri 0.4)
       (* (- 100 infrastructure_health_score) 0.3)
       (* (- 100 resource_security_score) 0.2)
       (* (- 100 crew_vitality_score) 0.1)))

  ;; ═══ REVOLUTIONARY ADAPTIVE ALLOCATION MATRIX ═══
  ;; 9-phase, 10-threat-level adaptive resource allocation system

  ;; Genesis Phase: Lightning-fast critical bootstrap
  (define genesis_allocation
    (cond
      (threat_extinction (begin (set! isru_alloc 0.65) (set! greenhouse_alloc 0.25) (set! heating_alloc 0.10)))
      (threat_apocalyptic (begin (set! isru_alloc 0.60) (set! greenhouse_alloc 0.28) (set! heating_alloc 0.12)))
      (threat_severe (begin (set! isru_alloc 0.55) (set! greenhouse_alloc 0.32) (set! heating_alloc 0.13)))
      (threat_critical (begin (set! isru_alloc 0.50) (set! greenhouse_alloc 0.35) (set! heating_alloc 0.15)))
      (threat_elevated (begin (set! isru_alloc 0.45) (set! greenhouse_alloc 0.38) (set! heating_alloc 0.17)))
      (threat_moderate (begin (set! isru_alloc 0.42) (set! greenhouse_alloc 0.40) (set! heating_alloc 0.18)))
      (threat_low (begin (set! isru_alloc 0.38) (set! greenhouse_alloc 0.42) (set! heating_alloc 0.20)))
      (threat_minimal (begin (set! isru_alloc 0.35) (set! greenhouse_alloc 0.45) (set! heating_alloc 0.20)))
      (threat_optimal (begin (set! isru_alloc 0.32) (set! greenhouse_alloc 0.48) (set! heating_alloc 0.20)))
      (threat_perfect (begin (set! isru_alloc 0.30) (set! greenhouse_alloc 0.50) (set! heating_alloc 0.20)))
      (true (begin (set! isru_alloc 0.40) (set! greenhouse_alloc 0.40) (set! heating_alloc 0.20)))))

  ;; Acceleration Phase: Rapid momentum building
  (define acceleration_allocation
    (cond
      (threat_extinction (begin (set! isru_alloc 0.58) (set! greenhouse_alloc 0.30) (set! heating_alloc 0.12)))
      (threat_apocalyptic (begin (set! isru_alloc 0.52) (set! greenhouse_alloc 0.36) (set! heating_alloc 0.12)))
      (threat_severe (begin (set! isru_alloc 0.47) (set! greenhouse_alloc 0.41) (set! heating_alloc 0.12)))
      (threat_critical (begin (set! isru_alloc 0.43) (set! greenhouse_alloc 0.45) (set! heating_alloc 0.12)))
      (threat_elevated (begin (set! isru_alloc 0.38) (set! greenhouse_alloc 0.50) (set! heating_alloc 0.12)))
      (threat_moderate (begin (set! isru_alloc 0.35) (set! greenhouse_alloc 0.53) (set! heating_alloc 0.12)))
      (threat_low (begin (set! isru_alloc 0.32) (set! greenhouse_alloc 0.56) (set! heating_alloc 0.12)))
      (threat_minimal (begin (set! isru_alloc 0.28) (set! greenhouse_alloc 0.60) (set! heating_alloc 0.12)))
      (threat_optimal (begin (set! isru_alloc 0.25) (set! greenhouse_alloc 0.63) (set! heating_alloc 0.12)))
      (threat_perfect (begin (set! isru_alloc 0.22) (set! greenhouse_alloc 0.66) (set! heating_alloc 0.12)))
      (true (begin (set! isru_alloc 0.35) (set! greenhouse_alloc 0.53) (set! heating_alloc 0.12)))))

  ;; Expansion Phase: Strategic growth optimization
  (define expansion_allocation
    (cond
      (threat_extinction (begin (set! isru_alloc 0.55) (set! greenhouse_alloc 0.33) (set! heating_alloc 0.12)))
      (threat_apocalyptic (begin (set! isru_alloc 0.48) (set! greenhouse_alloc 0.40) (set! heating_alloc 0.12)))
      (threat_severe (begin (set! isru_alloc 0.43) (set! greenhouse_alloc 0.45) (set! heating_alloc 0.12)))
      (threat_critical (begin (set! isru_alloc 0.38) (set! greenhouse_alloc 0.50) (set! heating_alloc 0.12)))
      (threat_elevated (begin (set! isru_alloc 0.35) (set! greenhouse_alloc 0.53) (set! heating_alloc 0.12)))
      (threat_moderate (begin (set! isru_alloc 0.32) (set! greenhouse_alloc 0.56) (set! heating_alloc 0.12)))
      (threat_low (begin (set! isru_alloc 0.28) (set! greenhouse_alloc 0.60) (set! heating_alloc 0.12)))
      (threat_minimal (begin (set! isru_alloc 0.25) (set! greenhouse_alloc 0.63) (set! heating_alloc 0.12)))
      (threat_optimal (begin (set! isru_alloc 0.22) (set! greenhouse_alloc 0.66) (set! heating_alloc 0.12)))
      (threat_perfect (begin (set! isru_alloc 0.20) (set! greenhouse_alloc 0.68) (set! heating_alloc 0.12)))
      (true (begin (set! isru_alloc 0.30) (set! greenhouse_alloc 0.58) (set! heating_alloc 0.12)))))

  ;; Fortification Phase: Infrastructure hardening
  (define fortification_allocation
    (cond
      (threat_extinction (begin (set! isru_alloc 0.52) (set! greenhouse_alloc 0.36) (set! heating_alloc 0.12)))
      (threat_apocalyptic (begin (set! isru_alloc 0.45) (set! greenhouse_alloc 0.43) (set! heating_alloc 0.12)))
      (threat_severe (begin (set! isru_alloc 0.40) (set! greenhouse_alloc 0.48) (set! heating_alloc 0.12)))
      (threat_critical (begin (set! isru_alloc 0.35) (set! greenhouse_alloc 0.53) (set! heating_alloc 0.12)))
      (threat_elevated (begin (set! isru_alloc 0.32) (set! greenhouse_alloc 0.56) (set! heating_alloc 0.12)))
      (threat_moderate (begin (set! isru_alloc 0.28) (set! greenhouse_alloc 0.60) (set! heating_alloc 0.12)))
      (threat_low (begin (set! isru_alloc 0.25) (set! greenhouse_alloc 0.63) (set! heating_alloc 0.12)))
      (threat_minimal (begin (set! isru_alloc 0.23) (set! greenhouse_alloc 0.65) (set! heating_alloc 0.12)))
      (threat_optimal (begin (set! isru_alloc 0.20) (set! greenhouse_alloc 0.68) (set! heating_alloc 0.12)))
      (threat_perfect (begin (set! isru_alloc 0.18) (set! greenhouse_alloc 0.70) (set! heating_alloc 0.12)))
      (true (begin (set! isru_alloc 0.28) (set! greenhouse_alloc 0.60) (set! heating_alloc 0.12)))))

  ;; Optimization Phase: Performance peak operations
  (define optimization_allocation
    (cond
      (threat_extinction (begin (set! isru_alloc 0.48) (set! greenhouse_alloc 0.40) (set! heating_alloc 0.12)))
      (threat_apocalyptic (begin (set! isru_alloc 0.42) (set! greenhouse_alloc 0.46) (set! heating_alloc 0.12)))
      (threat_severe (begin (set! isru_alloc 0.37) (set! greenhouse_alloc 0.51) (set! heating_alloc 0.12)))
      (threat_critical (begin (set! isru_alloc 0.33) (set! greenhouse_alloc 0.55) (set! heating_alloc 0.12)))
      (threat_elevated (begin (set! isru_alloc 0.30) (set! greenhouse_alloc 0.58) (set! heating_alloc 0.12)))
      (threat_moderate (begin (set! isru_alloc 0.27) (set! greenhouse_alloc 0.61) (set! heating_alloc 0.12)))
      (threat_low (begin (set! isru_alloc 0.24) (set! greenhouse_alloc 0.64) (set! heating_alloc 0.12)))
      (threat_minimal (begin (set! isru_alloc 0.22) (set! greenhouse_alloc 0.66) (set! heating_alloc 0.12)))
      (threat_optimal (begin (set! isru_alloc 0.19) (set! greenhouse_alloc 0.69) (set! heating_alloc 0.12)))
      (threat_perfect (begin (set! isru_alloc 0.17) (set! greenhouse_alloc 0.71) (set! heating_alloc 0.12)))
      (true (begin (set! isru_alloc 0.27) (set! greenhouse_alloc 0.61) (set! heating_alloc 0.12)))))

  ;; Mastery Phase: System mastery operations
  (define mastery_allocation
    (cond
      (threat_extinction (begin (set! isru_alloc 0.50) (set! greenhouse_alloc 0.38) (set! heating_alloc 0.12)))
      (threat_apocalyptic (begin (set! isru_alloc 0.44) (set! greenhouse_alloc 0.44) (set! heating_alloc 0.12)))
      (threat_severe (begin (set! isru_alloc 0.39) (set! greenhouse_alloc 0.49) (set! heating_alloc 0.12)))
      (threat_critical (begin (set! isru_alloc 0.35) (set! greenhouse_alloc 0.53) (set! heating_alloc 0.12)))
      (threat_elevated (begin (set! isru_alloc 0.32) (set! greenhouse_alloc 0.56) (set! heating_alloc 0.12)))
      (threat_moderate (begin (set! isru_alloc 0.29) (set! greenhouse_alloc 0.59) (set! heating_alloc 0.12)))
      (threat_low (begin (set! isru_alloc 0.26) (set! greenhouse_alloc 0.62) (set! heating_alloc 0.12)))
      (threat_minimal (begin (set! isru_alloc 0.24) (set! greenhouse_alloc 0.64) (set! heating_alloc 0.12)))
      (threat_optimal (begin (set! isru_alloc 0.21) (set! greenhouse_alloc 0.67) (set! heating_alloc 0.12)))
      (threat_perfect (begin (set! isru_alloc 0.19) (set! greenhouse_alloc 0.69) (set! heating_alloc 0.12)))
      (true (begin (set! isru_alloc 0.29) (set! greenhouse_alloc 0.59) (set! heating_alloc 0.12)))))

  ;; Perfection Phase: Operational perfection
  (define perfection_allocation
    (cond
      (threat_extinction (begin (set! isru_alloc 0.52) (set! greenhouse_alloc 0.36) (set! heating_alloc 0.12)))
      (threat_apocalyptic (begin (set! isru_alloc 0.46) (set! greenhouse_alloc 0.42) (set! heating_alloc 0.12)))
      (threat_severe (begin (set! isru_alloc 0.41) (set! greenhouse_alloc 0.47) (set! heating_alloc 0.12)))
      (threat_critical (begin (set! isru_alloc 0.37) (set! greenhouse_alloc 0.51) (set! heating_alloc 0.12)))
      (threat_elevated (begin (set! isru_alloc 0.34) (set! greenhouse_alloc 0.54) (set! heating_alloc 0.12)))
      (threat_moderate (begin (set! isru_alloc 0.31) (set! greenhouse_alloc 0.57) (set! heating_alloc 0.12)))
      (threat_low (begin (set! isru_alloc 0.28) (set! greenhouse_alloc 0.60) (set! heating_alloc 0.12)))
      (threat_minimal (begin (set! isru_alloc 0.26) (set! greenhouse_alloc 0.62) (set! heating_alloc 0.12)))
      (threat_optimal (begin (set! isru_alloc 0.23) (set! greenhouse_alloc 0.65) (set! heating_alloc 0.12)))
      (threat_perfect (begin (set! isru_alloc 0.21) (set! greenhouse_alloc 0.67) (set! heating_alloc 0.12)))
      (true (begin (set! isru_alloc 0.31) (set! greenhouse_alloc 0.57) (set! heating_alloc 0.12)))))

  ;; Transcendence Phase: Ultimate operations 
  (define transcendence_allocation
    (cond
      (threat_extinction (begin (set! isru_alloc 0.54) (set! greenhouse_alloc 0.34) (set! heating_alloc 0.12)))
      (threat_apocalyptic (begin (set! isru_alloc 0.48) (set! greenhouse_alloc 0.40) (set! heating_alloc 0.12)))
      (threat_severe (begin (set! isru_alloc 0.43) (set! greenhouse_alloc 0.45) (set! heating_alloc 0.12)))
      (threat_critical (begin (set! isru_alloc 0.39) (set! greenhouse_alloc 0.49) (set! heating_alloc 0.12)))
      (threat_elevated (begin (set! isru_alloc 0.36) (set! greenhouse_alloc 0.52) (set! heating_alloc 0.12)))
      (threat_moderate (begin (set! isru_alloc 0.33) (set! greenhouse_alloc 0.55) (set! heating_alloc 0.12)))
      (threat_low (begin (set! isru_alloc 0.30) (set! greenhouse_alloc 0.58) (set! heating_alloc 0.12)))
      (threat_minimal (begin (set! isru_alloc 0.28) (set! greenhouse_alloc 0.60) (set! heating_alloc 0.12)))
      (threat_optimal (begin (set! isru_alloc 0.25) (set! greenhouse_alloc 0.63) (set! heating_alloc 0.12)))
      (threat_perfect (begin (set! isru_alloc 0.23) (set! greenhouse_alloc 0.65) (set! heating_alloc 0.12)))
      (true (begin (set! isru_alloc 0.33) (set! greenhouse_alloc 0.55) (set! heating_alloc 0.12)))))

  ;; Infinity Phase: Beyond all limits
  (define infinity_allocation
    (cond
      (threat_extinction (begin (set! isru_alloc 0.56) (set! greenhouse_alloc 0.32) (set! heating_alloc 0.12)))
      (threat_apocalyptic (begin (set! isru_alloc 0.50) (set! greenhouse_alloc 0.38) (set! heating_alloc 0.12)))
      (threat_severe (begin (set! isru_alloc 0.45) (set! greenhouse_alloc 0.43) (set! heating_alloc 0.12)))
      (threat_critical (begin (set! isru_alloc 0.41) (set! greenhouse_alloc 0.47) (set! heating_alloc 0.12)))
      (threat_elevated (begin (set! isru_alloc 0.38) (set! greenhouse_alloc 0.50) (set! heating_alloc 0.12)))
      (threat_moderate (begin (set! isru_alloc 0.35) (set! greenhouse_alloc 0.53) (set! heating_alloc 0.12)))
      (threat_low (begin (set! isru_alloc 0.32) (set! greenhouse_alloc 0.56) (set! heating_alloc 0.12)))
      (threat_minimal (begin (set! isru_alloc 0.30) (set! greenhouse_alloc 0.58) (set! heating_alloc 0.12)))
      (threat_optimal (begin (set! isru_alloc 0.27) (set! greenhouse_alloc 0.61) (set! heating_alloc 0.12)))
      (threat_perfect (begin (set! isru_alloc 0.25) (set! greenhouse_alloc 0.63) (set! heating_alloc 0.12)))
      (true (begin (set! isru_alloc 0.35) (set! greenhouse_alloc 0.53) (set! heating_alloc 0.12)))))

  ;; Apply phase-specific allocation with error handling
  (cond
    (genesis_phase genesis_allocation)
    (acceleration_phase acceleration_allocation)
    (expansion_phase expansion_allocation) 
    (fortification_phase fortification_allocation)
    (optimization_phase optimization_allocation)
    (mastery_phase mastery_allocation)
    (perfection_phase perfection_allocation)
    (transcendence_phase transcendence_allocation)
    (infinity_phase infinity_allocation)
    (true expansion_allocation))  ;; Default fallback

  ;; ═══ HYPERINTELLIGENT FOOD RATIONING SYSTEM ═══
  ;; Neural network-inspired food rationing with health optimization
  (define neural_rationing_base
    (cond
      ((< food_days 1) 0.15)      ;; Emergency survival
      ((< food_days 3) 0.25)      ;; Critical rationing
      ((< food_days 5) 0.40)      ;; Severe rationing
      ((< food_days 8) 0.55)      ;; Moderate rationing
      ((< food_days 12) 0.70)     ;; Conservative rationing
      ((< food_days 18) 0.85)     ;; Light rationing
      ((< food_days 25) 0.95)     ;; Normal operations
      (true 1.1)))                ;; Abundance operations

  ;; Adaptive health-based adjustment
  (define health_adjustment
    (cond
      ((< crew_vitality_score 0.4) 1.15)  ;; Health boost needed
      ((< crew_vitality_score 0.6) 1.08)  ;; Moderate health boost
      ((< crew_vitality_score 0.8) 1.03)  ;; Light health boost
      (true 1.0)))

  ;; Threat-responsive rationing modulation
  (define threat_rationing_adjustment
    (cond
      (threat_extinction 0.85)
      (threat_apocalyptic 0.90)
      (threat_severe 0.93)
      (threat_critical 0.95)
      (threat_elevated 0.97)
      (true 1.0)))

  (set! food_ration 
    (max 0.15 (min 1.4 (* neural_rationing_base health_adjustment threat_rationing_adjustment))))

  ;; ═══ REVOLUTIONARY HYPERMAX INFRASTRUCTURE ORCHESTRATION ═══
  ;; Ultra-advanced 9-repair-bay system with predictive deployment

  ;; Lightning-fast bot deployment (sols 3-8) - Ultra early start
  (if (and (>= sol 3) (<= sol 8) (< bot_count 2))
      (set! build_item "worker_bot"))

  ;; Ultra-rapid solar deployment (sols 10-22) - Earlier than ever
  (if (and (>= sol 10) (<= sol 22) (< solar_count 3))
      (set! build_item "solar_array"))

  ;; Power efficiency solar (sols 25-35) - Tighter window
  (if (and (>= sol 25) (<= sol 35) (< solar_count 4) (< power_ratio 0.82))
      (set! build_item "solar_array"))

  ;; REVOLUTIONARY 9-REPAIR-BAY HYPERMAX SYSTEM
  ;; First repair bay (ultra-early protection) - Even earlier
  (if (and (>= sol 28) (<= sol 40) (< repair_count 1))
      (set! build_item "repair_bay"))

  ;; Second repair bay (compound damage shield) - Faster deployment
  (if (and (>= sol 50) (<= sol 68) (< repair_count 2)
           (or threat_elevated threat_critical threat_severe threat_apocalyptic threat_extinction
               (< ie 0.78)))
      (set! build_item "repair_bay"))

  ;; Third repair bay (infrastructure protection) - Earlier trigger
  (if (and (>= sol 78) (<= sol 98) (< repair_count 3)
           (or threat_critical threat_severe threat_apocalyptic threat_extinction
               (< se 0.78) (> neural_threat_weight 22)))
      (set! build_item "repair_bay"))

  ;; Fourth repair bay (system consolidation) - Accelerated deployment
  (if (and (>= sol 120) (<= sol 150) (< repair_count 4)
           (or threat_critical threat_severe threat_apocalyptic threat_extinction
               (> hypermax_effective_cri 32) (< (+ ie se) 1.45)))
      (set! build_item "repair_bay"))

  ;; Fifth repair bay (optimization insurance) - Earlier window
  (if (and (>= sol 180) (<= sol 220) (< repair_count 5)
           (or threat_severe threat_apocalyptic threat_extinction
               (> neural_threat_weight 28) (> hypermax_effective_cri 38)))
      (set! build_item "repair_bay"))

  ;; Sixth repair bay (mastery phase preparation) - Predictive timing
  (if (and (>= sol 250) (<= sol 290) (< repair_count 6)
           (or threat_apocalyptic threat_extinction (> hypermax_effective_cri 45)
               mastery_phase perfection_phase))
      (set! build_item "repair_bay"))

  ;; Seventh repair bay (transcendence readiness) - Strategic deployment
  (if (and (>= sol 330) (<= sol 380) (< repair_count 7)
           (or threat_extinction transcendence_phase infinity_phase
               (> neural_threat_weight 35) (> hypermax_effective_cri 55)))
      (set! build_item "repair_bay"))

  ;; Eighth repair bay (infinity preparation) - Revolutionary addition
  (if (and (>= sol 420) (<= sol 480) (< repair_count 8)
           (or threat_extinction infinity_phase
               (> neural_threat_weight 40) (> hypermax_effective_cri 65)))
      (set! build_item "repair_bay"))

  ;; Ninth repair bay (ultimate transcendence) - Hypermax culmination
  (if (and (>= sol 520) (<= sol 580) (< repair_count 9)
           (or threat_extinction infinity_phase
               (> neural_threat_weight 45) (> hypermax_effective_cri 75)))
      (set! build_item "repair_bay"))

  ;; Strategic greenhouse expansion - Enhanced timing
  (if (and (>= sol 45) (<= sol 85) (< food_days 12) (< greenhouse_count 3))
      (set! build_item "greenhouse"))

  ;; Additional greenhouse for food security
  (if (and (>= sol 120) (<= sol 180) (< food_days 15) (< greenhouse_count 5))
      (set! build_item "greenhouse"))

  ;; Hypermax module density optimization - Revolutionary 40+ modules
  (if (and (>= sol 150) (< module_count 32))
      (set! build_item
          (cond
            ((< repair_count 6) "repair_bay")
            ((< greenhouse_count 5) "greenhouse")
            ((< solar_count 8) "solar_array")
            (true "hab_module"))))

  ;; Transcendence infrastructure completion - Ultimate density
  (if (and transcendence_phase (< module_count 42))
      (set! build_item
          (cond
            ((< repair_count 8) "repair_bay")
            ((< greenhouse_count 7) "greenhouse")
            ((< solar_count 12) "solar_array")
            (true "hab_module"))))

  ;; Infinity infrastructure mastery - Beyond all limits
  (if (and infinity_phase (< module_count 50))
      (set! build_item
          (cond
            ((< repair_count 9) "repair_bay")
            ((< greenhouse_count 8) "greenhouse")
            ((< solar_count 15) "solar_array")
            (true "hab_module"))))

  ;; ═══ HYPERMAX QUANTUM STATUS LOGGING ═══
  (define phase_name
    (cond
      (genesis_phase "GENESIS")
      (acceleration_phase "ACCELERATION")
      (expansion_phase "EXPANSION")
      (fortification_phase "FORTIFICATION")
      (optimization_phase "OPTIMIZATION")
      (mastery_phase "MASTERY")
      (perfection_phase "PERFECTION")
      (transcendence_phase "TRANSCENDENCE")
      (infinity_phase "INFINITY")
      (true "HYPERMAX")))

  (define threat_name
    (cond
      (threat_extinction "EXTINCTION")
      (threat_apocalyptic "APOCALYPTIC")
      (threat_severe "SEVERE")
      (threat_critical "CRITICAL")
      (threat_elevated "ELEVATED")
      (threat_moderate "MODERATE")
      (threat_low "LOW")
      (threat_minimal "MINIMAL")
      (threat_optimal "OPTIMAL")
      (threat_perfect "PERFECT")
      (true "UNKNOWN")))

  (log (concat "  🌌 Phase: " phase_name " | 🎯 Threat: " threat_name " | 🧠 Neural Weight: " (string (round neural_threat_weight))))
  (log (concat "  ⚡ CRI: " (string (round cri)) " | 🔮 Effective: " (string (round hypermax_effective_cri)) " | 🏗️ Infrastructure: " (string (round (* infrastructure_health_score 100))) "%"))
  (log (concat "  🔧 Allocation — ISRU:" (string (round (* isru_alloc 100))) "% | 🌱 Greenhouse:" (string (round (* greenhouse_alloc 100))) "% | 🔥 Heating:" (string (round (* heating_alloc 100))) "%"))
  (log (concat "  🍽️ Food Ration: " (string (round (* food_ration 100))) "% | ⏱️ Days: O2=" (string o2_days) " Food=" (string food_days)))
  (log (concat "  🏭 Infrastructure: " (string repair_count) " repair | " (string solar_count) " solar | " (string greenhouse_count) " greenhouse | " (string module_count) " modules"))
  (log (concat "  💪 Crew Vitality: " (string (round (* crew_vitality_score 100))) "% | 🔋 Power Ratio: " (string (round (* power_ratio 100))) "%"))
)