;; COPILOT ADAPTIVE SURVIVAL CHAMPION v1
;; Innovation: Balance aggressive building with reliable survival
;; Target: Beat 441 sols while maintaining crew survival
;; Philosophy: Smart risk management with aggressive building when safe

(begin
  (define _agent_name "Copilot Adaptive Survival Champion v1")
  (define _agent_desc "Balanced survival and building strategy for gauntlet breakthrough")

  (log (concat "🎯🛡️⚡ SURVIVAL CHAMPION — Sol " (string sol) " — Smart Risk Management"))

  ;; ═══ MISSION PHASE INTELLIGENCE ═══
  ;; Dynamic mission phases based on sol and risk state
  (define mission_phase
    (cond
      ((< sol 100) "FOUNDATION")     ;; Sol 1-99: Build foundation
      ((< sol 250) "EXPANSION")      ;; Sol 100-249: Expand carefully
      ((< sol 400) "OPTIMIZATION")   ;; Sol 250-399: Optimize for survival
      ((< sol 550) "CONSOLIDATION")  ;; Sol 400-549: Prepare for endgame
      (true "ENDGAME")))             ;; Sol 550+: Survival priority

  ;; ═══ INTELLIGENT THREAT ASSESSMENT ═══
  ;; Multi-dimensional risk evaluation
  (define resource_crisis (or (< o2_days 3) (< food_days 4) (< water_days 3)))
  (define power_emergency (< power 40))
  (define health_critical (< (/ (+ crew_hp) (max 1 crew_alive)) 70))
  (define compound_danger (and (> sol 300) (> colony_risk_index 60)))

  (define threat_level
    (cond
      ((or resource_crisis power_emergency health_critical) "CRITICAL")
      ((or (> colony_risk_index 75) compound_danger) "HIGH")
      ((> colony_risk_index 50) "ELEVATED")
      ((> colony_risk_index 30) "MODERATE")
      (true "NORMAL")))

  ;; ═══ ADAPTIVE RESOURCE ALLOCATION ═══
  ;; Smart allocation based on threat level and mission phase
  (define allocation_strategy
    (cond
      ;; CRITICAL - Survival only
      ((equal? threat_level "CRITICAL")
       (list 0.45 0.50 0.05))
       
      ;; HIGH - Conservative survival focus
      ((equal? threat_level "HIGH")
       (list 0.30 0.65 0.05))
       
      ;; ELEVATED - Balanced approach
      ((equal? threat_level "ELEVATED")
       (list 0.20 0.75 0.05))
       
      ;; MODERATE - Building focused
      ((equal? threat_level "MODERATE")
       (list 0.15 0.80 0.05))
       
      ;; NORMAL - Maximum building efficiency
      ((equal? threat_level "NORMAL")
       (cond
         ;; Foundation phase - moderate building
         ((equal? mission_phase "FOUNDATION") (list 0.12 0.83 0.05))
         ;; Expansion phase - aggressive building
         ((equal? mission_phase "EXPANSION") (list 0.08 0.87 0.05))
         ;; Later phases - balanced for survival
         (true (list 0.15 0.80 0.05))))
       
      ;; Fallback
      (true (list 0.20 0.75 0.05))))

  (define base_alloc (nth allocation_strategy 0))
  (set! isru_alloc (nth base_alloc 0))
  (set! greenhouse_alloc (nth base_alloc 1))
  (set! heating_alloc (nth base_alloc 2))

  ;; ═══ INTELLIGENT FOOD RATIONING ═══
  ;; Adaptive rationing based on abundance and crew health
  (define base_rationing
    (cond
      ((< food_days 2) 0.40)      ;; Emergency rationing
      ((< food_days 5) 0.60)      ;; Crisis rationing
      ((< food_days 10) 0.75)     ;; Conservative rationing
      ((< food_days 20) 0.90)     ;; Standard operations
      ((< food_days 35) 1.05)     ;; Optimal operations
      (true 1.20)))               ;; Abundance operations

  ;; Health-based adjustment
  (define health_ratio (/ (+ crew_hp) (max 1 (* crew_alive 100))))
  (define health_adjustment
    (cond
      ((< health_ratio 0.6) 1.5)   ;; Major health boost
      ((< health_ratio 0.75) 1.25) ;; Moderate health boost
      ((< health_ratio 0.85) 1.1)  ;; Minor health boost
      (true 1.0)))                 ;; No adjustment needed

  ;; Mission phase adjustment
  (define phase_adjustment
    (cond
      ((equal? mission_phase "ENDGAME") 1.3)     ;; Extra careful in endgame
      ((equal? mission_phase "CONSOLIDATION") 1.1) ;; Slightly conservative
      (true 1.0)))

  (set! food_ration 
    (max 0.30 (min 1.8 (* base_rationing health_adjustment phase_adjustment))))

  ;; ═══ ADAPTIVE SCORE TRACKING ═══
  (define survival_score
    (let* ((resource_security (* (+ o2_days food_days) 8))
           (infrastructure_health (* (+ ie se) 120))
           (crew_wellness (* crew_alive (/ (+ crew_hp) (max 1 crew_alive)) 4))
           (threat_penalty (* colony_risk_index -3)))
      (+ resource_security infrastructure_health crew_wellness threat_penalty)))

  ;; ═══ STATUS DISPLAY ═══
  (log (concat "  🎯 Mission Phase: " mission_phase " | Threat Level: " threat_level))
  (log (concat "  🛡️ Survival Score: " (string (round survival_score)) " | Health Ratio: " (string (round (* health_ratio 100))) "%"))
  (log (concat "  ⚡ Smart Allocation — ISRU:" (string (round (* isru_alloc 100))) "% | Green:" (string (round (* greenhouse_alloc 100))) "% | Heat:" (string (round (* heating_alloc 100))) "%"))
  (log (concat "  🎯 Resources — O2:" (string o2_days) "d Food:" (string food_days) "d Water:" (string water_days) "d | Power:" (string power)))
  (log (concat "  💪 Crew Status — Alive:" (string crew_alive) " | Health:" (string (round (* health_ratio 100))) "% | CRI:" (string colony_risk_index)))

  ;; ═══ ADAPTIVE OUTPUT ═══
  (concat "🎯🛡️⚡ SurvivalChampion Sol " (string sol) " — " mission_phase "/" threat_level
    " | SS:" (string (round survival_score))
    " | I:" (string (round (* isru_alloc 100)))
    "% G:" (string (round (* greenhouse_alloc 100)))
    "% | R:" (string (round (* food_ration 100)))
    "% | O2:" (string o2_days) "d F:" (string food_days) "d"))