;; COPILOT V4 ULTRA CRI OPTIMIZATION BREAKTHROUGH V1
;; Strategy: Achieve P75 CRI < 8 for maximum score gain
;; Current best: 95,790 with CRI=11 → Target: 95,820+ with CRI<8
;; Ultra-aggressive resource buffering for perfect CRI control

(begin
  (define _agent_name "Copilot V4 Ultra CRI Optimization Breakthrough v1")
  (define _agent_desc "Ultra-aggressive CRI minimization targeting P75 CRI < 8")
  
  (log (concat "🎯⚡ ULTRA CRI OPTIMIZER — Sol " (string sol) " — CRI:" (string colony_risk_index) " — Target: <8"))
  
  ;; ═══ ULTRA CRI TARGET ANALYSIS ═══ 
  ;; CRI Formula: 5 + power_penalty + events*6 + resource_penalties
  ;; Target CRI = 5 (base) + 0 (power>150) + 0-6 (events) + 0 (all resources >5d) = 5-11
  ;; P75 target < 8 means most runs should have CRI 5-7
  
  ;; ═══ ULTRA RESOURCE BUFFER TARGETS ═══
  ;; Maintain MASSIVE resource buffers to guarantee no CRI penalties
  (define ultra_o2_target 8.0)     ;; 60% over minimum requirement
  (define ultra_h2o_target 8.0)    ;; 60% over minimum requirement  
  (define ultra_food_target 8.0)   ;; 60% over minimum requirement
  
  ;; ═══ PHASE-BASED ULTRA STRATEGY ═══
  (define phase_foundation (< sol 150))
  (define phase_buffer_build (and (>= sol 150) (< sol 350)))
  (define phase_optimization (and (>= sol 350) (< sol 600))) 
  (define phase_v4_perfection (>= sol 600))
  
  ;; ═══ ULTRA CRI BUFFER ALLOCATION ═══
  ;; Emergency allocation when any buffer is low
  (define ultra_o2_need
    (cond
      ((< o2_days 2.0) 0.80)      ;; Emergency - maximum allocation
      ((< o2_days 4.0) 0.70)      ;; High priority  
      ((< o2_days 6.0) 0.55)      ;; Build to buffer
      ((< o2_days 8.0) 0.40)      ;; Maintain ultra buffer
      ((< o2_days 12.0) 0.25)     ;; Sustain excellent buffer
      (true 0.15)))               ;; Minimal when abundant
  
  (define ultra_food_need
    (cond
      ((< food_days 2.0) 0.75)    ;; Emergency food
      ((< food_days 4.0) 0.65)    ;; High priority
      ((< food_days 6.0) 0.50)    ;; Build to buffer
      ((< food_days 8.0) 0.35)    ;; Maintain ultra buffer
      ((< food_days 12.0) 0.20)   ;; Sustain excellent buffer
      (true 0.10)))               ;; Minimal when abundant
  
  ;; ═══ ULTRA CRI SAFETY SYSTEM ═══
  ;; Massive boost when CRI approaches danger zone
  (define ultra_cri_response
    (cond
      ((< colony_risk_index 6) 1.0)      ;; Perfect CRI - maintain
      ((< colony_risk_index 8) 1.2)      ;; Good CRI - boost slightly  
      ((< colony_risk_index 10) 1.5)     ;; Warning CRI - significant boost
      ((< colony_risk_index 15) 1.8)     ;; High CRI - major boost
      (true 2.2)))                       ;; Crisis CRI - maximum boost
  
  ;; ═══ PHASE-OPTIMIZED BASE ALLOCATION ═══
  (define ultra_base_allocation
    (cond
      ;; Foundation - build sustainable ultra-buffers
      (phase_foundation 0.90)
      
      ;; Buffer building - focus on CRI elimination
      (phase_buffer_build 0.85)
      
      ;; Optimization - fine-tune for perfect CRI
      (phase_optimization 0.88)
      
      ;; V4 perfection - maximum CRI control
      (phase_v4_perfection 0.95)
      
      ;; Default ultra-conservative
      (true 0.90)))
  
  ;; ═══ ULTRA EVENT MITIGATION ═══
  ;; Events add 6 CRI points each - minimize active events
  (define event_cri_penalty (* 6 (length events)))
  (define high_event_risk (> event_cri_penalty 12))  ;; 2+ events = 12+ penalty
  
  ;; Boost allocation if event risk is high
  (define event_response_multiplier (if high_event_risk 1.3 1.0))
  
  ;; ═══ FINAL ULTRA ALLOCATIONS ═══
  (define ultra_isru_alloc (* ultra_base_allocation ultra_o2_need ultra_cri_response event_response_multiplier))
  (define ultra_greenhouse_alloc (* ultra_base_allocation ultra_food_need ultra_cri_response event_response_multiplier))
  (define ultra_heating_alloc (max 0.05 (min 0.95 (- 1.0 ultra_isru_alloc ultra_greenhouse_alloc))))
  
  ;; Apply with ultra-conservative bounds
  (set! isru_alloc (max 0.15 (min 0.85 ultra_isru_alloc)))
  (set! greenhouse_alloc (max 0.15 (min 0.80 ultra_greenhouse_alloc)))
  (set! heating_alloc (max 0.05 (min 0.85 ultra_heating_alloc)))
  (set! building_alloc 0.0)  ;; Hardcoded building handles modules
  
  ;; ═══ ULTRA FOOD RATIONING FOR CRI ═══
  ;; Optimize food usage to maintain ultra buffer
  (define ultra_food_ration
    (cond
      ((< food_days 3.0) 0.40)    ;; Emergency - but preserve crew
      ((< food_days 5.0) 0.60)    ;; Build buffer aggressively  
      ((< food_days 7.0) 0.75)    ;; Approach ultra target
      ((< food_days 10.0) 0.85)   ;; Maintain ultra buffer
      ((< food_days 15.0) 0.90)   ;; Excellent buffer
      (true 0.95)))               ;; Maximum buffer - near full rations
  
  (set! food_ration ultra_food_ration)
  
  ;; ═══ ULTRA CRI ANALYSIS & TRACKING ═══
  (define power_penalty (if (< power 50) 25 (if (< power 150) 10 0)))
  (define o2_penalty (if (< o2_days 5) 20 0))
  (define h2o_penalty (if (< h2o_days 5) 20 0))
  (define food_penalty (if (< food_days 5) 20 0))
  (define total_resource_penalty (+ o2_penalty h2o_penalty food_penalty))
  
  (define calculated_cri (+ 5 power_penalty event_cri_penalty total_resource_penalty))
  
  (log (concat "  🎯 Phase: " 
    (if phase_foundation "FOUNDATION"
    (if phase_buffer_build "BUFFER-BUILD"
    (if phase_optimization "OPTIMIZATION" "V4-PERFECTION")))))
  
  (log (concat "  📊 CRI Breakdown: " (string colony_risk_index) " = 5+" (string power_penalty) "+" (string event_cri_penalty) "+" (string total_resource_penalty) " (calc:" (string calculated_cri) ")"))
  
  (define buffer_status 
    (concat "O2:" (string (round o2_days 1)) "d" (if (>= o2_days ultra_o2_target) "✓" "⚠")
            " H2O:" (string (round h2o_days 1)) "d" (if (>= h2o_days ultra_h2o_target) "✓" "⚠")  
            " Food:" (string (round food_days 1)) "d" (if (>= food_days ultra_food_target) "✓" "⚠")))
  
  (log (concat "  🛡️ Ultra Buffers: " buffer_status))
  (log (concat "  ⚡ Power: " (string (round power)) "kWh" (if (> power 150) " ✓Safe" " ⚠Low") " | Events:" (string (length events)) " | CRI Response:" (string (round (* ultra_cri_response 100))) "%"))
  (log (concat "  🔧 Ultra Allocations: I:" (string (round (* isru_alloc 100))) "% G:" (string (round (* greenhouse_alloc 100))) "% H:" (string (round (* heating_alloc 100))) "% | Ration:" (string (round (* food_ration 100))) "%"))
  
  ;; ═══ SCORE PROJECTION WITH CRI OPTIMIZATION ═══
  (if (> sol 600)
    (let ((projected_sols (round (+ sol (* (- 732 sol) 0.99))))  ;; Assume 99% completion rate
          (projected_cri (max 5 (min colony_risk_index 12)))      ;; Conservative CRI estimate
          (projected_score (+ (* projected_sols 100) 1500 1200 20000 (* projected_cri -10))))
      (log (concat "  🏆 Projected Final: " (string projected_score) " (sols:" (string projected_sols) " cri:" (string projected_cri) ") | Target: >95,790"))))
  
  ;; ═══ ULTRA OUTPUT SUMMARY ═══
  (concat "ULTRA-CRI Sol " (string sol) 
    " | CRI:" (string colony_risk_index) "/8"
    " | Buffers:" (if (and (>= o2_days 5) (>= h2o_days 5) (>= food_days 5)) "SAFE" "BUILDING")
    " | Events:" (string (length events))
    " | Ultra-mode"))