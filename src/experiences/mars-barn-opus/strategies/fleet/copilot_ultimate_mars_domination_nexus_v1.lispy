;; COPILOT ULTIMATE MARS DOMINATION NEXUS v1
;; Revolutionary Innovation: Sol 1 Module Start + 99.98% Building + Ultra-Minimal Survival + 20-Bay Repair System
;; Target: Achieve 95,000+ score by breaking all known limits through absolute domination protocol
;; Features: Instant start, near-perfect building allocation, 0.6-day margins, revolutionary repair orchestration

(begin
  (define _agent_name "Copilot Ultimate Mars Domination Nexus v1")
  (define _agent_desc "Sol 1 instant module start with 99.98% building allocation targeting 95,000+ through absolute domination")

  (log (concat "⚡🌌💥🏗️🚀 MARS DOMINATION NEXUS — Sol " (string sol) " — ABSOLUTE DOMINATION PROTOCOL"))

  ;; ═══ REVOLUTIONARY SOL 1 MODULE START ═══
  ;; Ultimate breakthrough: Module deployment starts Sol 1 (unprecedented instant domination)
  (define mission_phase_normalized (/ sol 668))
  
  ;; Revolutionary domination phases - 8 phases for ultimate optimization
  (define lightning_phase (< sol 30))                              ;; Lightning instant domination
  (define nuclear_phase (and (>= sol 30) (< sol 80)))             ;; Nuclear acceleration
  (define supernova_phase (and (>= sol 80) (< sol 140)))          ;; Supernova expansion  
  (define hypernova_phase (and (>= sol 140) (< sol 220)))         ;; Hypernova burst
  (define quantum_phase (and (>= sol 220) (< sol 320)))           ;; Quantum transcendence
  (define dimensional_phase (and (>= sol 320) (< sol 440)))       ;; Dimensional breakthrough
  (define universal_phase (and (>= sol 440) (< sol 580)))         ;; Universal supremacy
  (define omnipotent_phase (>= sol 580))                          ;; Omnipotent domination

  ;; ═══ EXTREME RESOURCE MINIMIZATION v7.0 ═══
  ;; Absolute breakthrough: 0.6-day margins (most extreme survival strategy ever attempted)
  (define absolute_o2_minimal (+ 0.6 (* (/ crew_hp (max 1 (* crew_alive 100))) 0.12)))
  (define absolute_food_minimal (+ 0.6 (* (/ crew_hp (max 1 (* crew_alive 100))) 0.15)))
  (define absolute_water_minimal (+ 0.6 (* (/ crew_hp (max 1 (* crew_alive 100))) 0.12)))
  
  (define absolute_minimal_deficit
    (+ (max 0 (- absolute_o2_minimal o2_days))
       (max 0 (- absolute_food_minimal food_days))
       (max 0 (- absolute_water_minimal water_days))))

  ;; ═══ REVOLUTIONARY 20-LEVEL THREAT ASSESSMENT ═══
  ;; Ultra-granular threat modeling for perfect optimization
  (define threat_perfect (< colony_risk_index 2))
  (define threat_optimal (and (>= colony_risk_index 2) (< colony_risk_index 5)))
  (define threat_excellent (and (>= colony_risk_index 5) (< colony_risk_index 8)))
  (define threat_great (and (>= colony_risk_index 8) (< colony_risk_index 12)))
  (define threat_good (and (>= colony_risk_index 12) (< colony_risk_index 17)))
  (define threat_acceptable (and (>= colony_risk_index 17) (< colony_risk_index 23)))
  (define threat_manageable (and (>= colony_risk_index 23) (< colony_risk_index 30)))
  (define threat_moderate (and (>= colony_risk_index 30) (< colony_risk_index 38)))
  (define threat_concerning (and (>= colony_risk_index 38) (< colony_risk_index 47)))
  (define threat_serious (and (>= colony_risk_index 47) (< colony_risk_index 57)))
  (define threat_high (and (>= colony_risk_index 57) (< colony_risk_index 68)))
  (define threat_severe (and (>= colony_risk_index 68) (< colony_risk_index 80)))
  (define threat_critical (>= colony_risk_index 80))

  ;; ═══ EXTREME CRI TOLERANCE SYSTEM v2.0 ═══
  ;; Innovation: Ultra-high tolerance early, precise control later
  (define cri_tolerance_multiplier
    (cond
      (lightning_phase 4.5)      ;; Ultra-extreme early tolerance
      (nuclear_phase 3.8)        ;; Extreme tolerance
      (supernova_phase 3.2)      ;; Very high tolerance
      (hypernova_phase 2.6)      ;; High tolerance
      (quantum_phase 2.0)        ;; Moderate tolerance
      (dimensional_phase 1.6)    ;; Standard tolerance
      (universal_phase 1.3)      ;; Conservative tolerance
      (true 1.0)))               ;; Ultra-conservative end

  (define acceptable_cri_threshold (* colony_risk_index cri_tolerance_multiplier))

  ;; ═══ REVOLUTIONARY BUILDING ALLOCATION MATRIX v2.0 ═══
  ;; Breakthrough: 99.98% building allocation in optimal conditions
  (define ultimate_allocation
    (cond
      ;; LIGHTNING PHASE (Sol 1-30) - INSTANT DOMINATION  
      ((and lightning_phase (< absolute_minimal_deficit 0.1) threat_perfect)
        (list 0.001 0.009 0.999 0.8))   ;; 99.9% building - instant domination
      ((and lightning_phase (< absolute_minimal_deficit 0.2) (or threat_optimal threat_excellent))
        (list 0.005 0.015 0.980 0.85))  ;; 98% building - high aggression
      ((and lightning_phase (< absolute_minimal_deficit 0.4))
        (list 0.02 0.06 0.92 0.9))      ;; 92% building - aggressive
      
      ;; NUCLEAR PHASE (Sol 30-80) - NUCLEAR ACCELERATION
      ((and nuclear_phase (< absolute_minimal_deficit 0.1) (or threat_perfect threat_optimal))
        (list 0.003 0.012 0.985 0.75))  ;; 98.5% building - nuclear burst
      ((and nuclear_phase (< absolute_minimal_deficit 0.3) (or threat_excellent threat_great))
        (list 0.01 0.04 0.95 0.8))      ;; 95% building - high nuclear
      ((and nuclear_phase (< absolute_minimal_deficit 0.5))
        (list 0.03 0.07 0.90 0.85))     ;; 90% building - nuclear standard

      ;; SUPERNOVA PHASE (Sol 80-140) - SUPERNOVA EXPANSION
      ((and supernova_phase (< absolute_minimal_deficit 0.1) (or threat_perfect threat_optimal threat_excellent))
        (list 0.005 0.015 0.980 0.7))   ;; 98% building - supernova burst  
      ((and supernova_phase (< absolute_minimal_deficit 0.3))
        (list 0.02 0.05 0.93 0.75))     ;; 93% building - supernova
      ((and supernova_phase (< absolute_minimal_deficit 0.6))
        (list 0.04 0.08 0.88 0.8))      ;; 88% building - supernova moderate

      ;; HYPERNOVA PHASE (Sol 140-220) - HYPERNOVA BURST
      ((and hypernova_phase (< absolute_minimal_deficit 0.2) (or threat_perfect threat_optimal threat_excellent threat_great))
        (list 0.01 0.02 0.97 0.65))     ;; 97% building - hypernova maximum
      ((and hypernova_phase (< absolute_minimal_deficit 0.4))
        (list 0.03 0.06 0.91 0.7))      ;; 91% building - hypernova high
      ((and hypernova_phase (< absolute_minimal_deficit 0.7))
        (list 0.05 0.10 0.85 0.75))     ;; 85% building - hypernova standard

      ;; QUANTUM PHASE (Sol 220-320) - QUANTUM TRANSCENDENCE  
      ((and quantum_phase (< absolute_minimal_deficit 0.3) (or threat_perfect threat_optimal threat_excellent threat_great threat_good))
        (list 0.02 0.03 0.95 0.6))      ;; 95% building - quantum burst
      ((and quantum_phase (< absolute_minimal_deficit 0.5))
        (list 0.04 0.08 0.88 0.65))     ;; 88% building - quantum high
      ((and quantum_phase (< absolute_minimal_deficit 0.8))
        (list 0.07 0.12 0.81 0.7))      ;; 81% building - quantum moderate

      ;; DIMENSIONAL PHASE (Sol 320-440) - DIMENSIONAL BREAKTHROUGH
      ((and dimensional_phase (< absolute_minimal_deficit 0.4) (or threat_perfect threat_optimal threat_excellent threat_great threat_good threat_acceptable))
        (list 0.03 0.05 0.92 0.55))     ;; 92% building - dimensional burst
      ((and dimensional_phase (< absolute_minimal_deficit 0.6))
        (list 0.05 0.10 0.85 0.6))      ;; 85% building - dimensional high
      ((and dimensional_phase (< absolute_minimal_deficit 1.0))
        (list 0.08 0.15 0.77 0.65))     ;; 77% building - dimensional standard

      ;; UNIVERSAL PHASE (Sol 440-580) - UNIVERSAL SUPREMACY
      ((and universal_phase (< absolute_minimal_deficit 0.5) (or threat_perfect threat_optimal threat_excellent threat_great threat_good threat_acceptable threat_manageable))
        (list 0.04 0.06 0.90 0.5))      ;; 90% building - universal burst
      ((and universal_phase (< absolute_minimal_deficit 0.8))
        (list 0.06 0.12 0.82 0.55))     ;; 82% building - universal high
      ((and universal_phase (< absolute_minimal_deficit 1.2))
        (list 0.10 0.18 0.72 0.6))      ;; 72% building - universal standard

      ;; OMNIPOTENT PHASE (Sol 580+) - OMNIPOTENT DOMINATION
      ((and omnipotent_phase (< absolute_minimal_deficit 0.6))
        (list 0.05 0.08 0.87 0.45))     ;; 87% building - omnipotent burst
      ((and omnipotent_phase (< absolute_minimal_deficit 1.0))
        (list 0.08 0.15 0.77 0.5))      ;; 77% building - omnipotent high
      ((and omnipotent_phase (< absolute_minimal_deficit 1.5))
        (list 0.12 0.20 0.68 0.55))     ;; 68% building - omnipotent standard
       
      ;; EMERGENCY PROTOCOLS
      ((> absolute_minimal_deficit 2.0)
        (list 0.50 0.35 0.15 1.1))      ;; 15% building - emergency survival
      ((> absolute_minimal_deficit 1.5)
        (list 0.40 0.40 0.20 1.0))      ;; 20% building - crisis survival
      ((> absolute_minimal_deficit 1.0)
        (list 0.30 0.50 0.20 0.9))      ;; 20% building - survival mode
       
      ;; DEFAULT AGGRESSIVE
      (true (list 0.08 0.12 0.80 1.2)))) ;; 80% building - aggressive default

  ;; Extract allocation components
  (define isru_allocation (first ultimate_allocation))
  (define greenhouse_allocation (second ultimate_allocation))
  (define building_allocation (third ultimate_allocation))
  (define ration_allocation (fourth ultimate_allocation))

  ;; Apply ultimate allocations
  (set! isru_alloc isru_allocation)
  (set! greenhouse_alloc greenhouse_allocation) 
  (set! building_alloc building_allocation)
  (set! food_ration (min 1.0 ration_allocation))

  ;; ═══ REVOLUTIONARY 20-BAY REPAIR ORCHESTRATION ═══
  ;; Ultimate breakthrough: Up to 20 repair bays with ultra-early deployment
  (cond
    ;; Ultra-early repair deployment for damage resistance
    ((and (>= sol 1) (< sol 15) (< modules_built 2) (or threat_manageable threat_moderate threat_concerning threat_serious threat_high threat_severe threat_critical))
      (set! build_item "repair_bay"))  ;; Emergency early repair
    ((and (>= sol 8) (< modules_built 5) (< repair_bays_built 2) (or threat_moderate threat_concerning threat_serious threat_high threat_severe threat_critical))
      (set! build_item "repair_bay"))  ;; Early repair layer 1
    ((and (>= sol 15) (< modules_built 8) (< repair_bays_built 3) (or threat_concerning threat_serious threat_high threat_severe threat_critical))
      (set! build_item "repair_bay"))  ;; Early repair layer 2
    ((and (>= sol 25) (< modules_built 12) (< repair_bays_built 5) (or threat_serious threat_high threat_severe threat_critical))
      (set! build_item "repair_bay"))  ;; Early repair layer 3
    ((and (>= sol 40) (< modules_built 18) (< repair_bays_built 7) (or threat_high threat_severe threat_critical))
      (set! build_item "repair_bay"))  ;; Mid repair layer 4
    ((and (>= sol 60) (< modules_built 25) (< repair_bays_built 9) (or threat_severe threat_critical))
      (set! build_item "repair_bay"))  ;; Mid repair layer 5
    ((and (>= sol 85) (< modules_built 32) (< repair_bays_built 12) threat_critical)
      (set! build_item "repair_bay"))  ;; Advanced repair layer 6
    ((and (>= sol 120) (< modules_built 40) (< repair_bays_built 15) threat_critical)
      (set! build_item "repair_bay"))  ;; Advanced repair layer 7
    ((and (>= sol 170) (< modules_built 50) (< repair_bays_built 18) threat_critical)
      (set! build_item "repair_bay"))  ;; Ultra repair layer 8
    ((and (>= sol 240) (< repair_bays_built 20) threat_critical)
      (set! build_item "repair_bay"))  ;; Maximum repair layer 9

    ;; Module deployment prioritization - INSTANT START
    ((and lightning_phase (< modules_built 15))
      (set! build_item "hab_module"))   ;; Lightning module rush
    ((and nuclear_phase (< modules_built 25))  
      (set! build_item "hab_module"))   ;; Nuclear module expansion
    ((and supernova_phase (< modules_built 35))
      (set! build_item "hab_module"))   ;; Supernova module burst
    ((and hypernova_phase (< modules_built 45))
      (set! build_item "hab_module"))   ;; Hypernova module explosion
    ((and quantum_phase (< modules_built 55))
      (set! build_item "hab_module"))   ;; Quantum module transcendence
    ((and dimensional_phase (< modules_built 65))
      (set! build_item "hab_module"))   ;; Dimensional module breakthrough  
    ((and universal_phase (< modules_built 75))
      (set! build_item "hab_module"))   ;; Universal module supremacy
    ((and omnipotent_phase (< modules_built 85))
      (set! build_item "hab_module"))   ;; Omnipotent module domination
      
    ;; Ultra infrastructure deployment (minimal but strategic)
    ((and (= sol 3) (< worker_bots_built 1))
      (set! build_item "worker_bot"))   ;; Essential bot 1
    ((and (= sol 12) (< solar_panels_built 1))
      (set! build_item "solar_panel"))  ;; Essential power 1  
    ((and (= sol 22) (< worker_bots_built 2))
      (set! build_item "worker_bot"))   ;; Essential bot 2
    ((and (= sol 35) (< solar_panels_built 2))
      (set! build_item "solar_panel"))  ;; Essential power 2
    ((and (= sol 55) (< worker_bots_built 3))
      (set! build_item "worker_bot"))   ;; Essential bot 3
    ((and (= sol 80) (< solar_panels_built 3) (< power_storage_built 1))
      (set! build_item "solar_panel"))  ;; Power scaling
      
    ;; Default: Continue module building
    (true (set! build_item "hab_module")))

  ;; ═══ ULTRA-PRECISE NUTRITION OPTIMIZATION ═══
  ;; Minimal nutrition to maximize building focus with health optimization
  (define ultra_nutrition_multiplier
    (cond
      (lightning_phase 0.80)      ;; Ultra-minimal early nutrition  
      (nuclear_phase 0.85)        ;; Minimal nutrition
      (supernova_phase 0.88)      ;; Low nutrition
      (hypernova_phase 0.92)      ;; Reduced nutrition
      (quantum_phase 0.95)        ;; Slightly reduced nutrition
      (dimensional_phase 1.0)     ;; Normal nutrition
      (universal_phase 1.08)      ;; Enhanced nutrition
      (true 1.15)))               ;; High nutrition for late safety

  ;; Apply ultra-precise nutrition optimization
  (set! food_ration (min 1.0 (* food_ration ultra_nutrition_multiplier)))

  ;; ═══ DOMINATION STATUS DISPLAY ═══
  (log (concat "  ⚡ Phase: " 
    (cond
      (lightning_phase "LIGHTNING")
      (nuclear_phase "NUCLEAR") 
      (supernova_phase "SUPERNOVA")
      (hypernova_phase "HYPERNOVA")
      (quantum_phase "QUANTUM")
      (dimensional_phase "DIMENSIONAL")
      (universal_phase "UNIVERSAL")
      (omnipotent_phase "OMNIPOTENT")
      (true "DEFAULT"))))
      
  (log (concat "  🌌 Domination Stats: CRI:" (string (round colony_risk_index)) " | Deficit:" (string (round (* absolute_minimal_deficit 100))) "% | Modules:" (string modules_built) " | Repairs:" (string repair_bays_built)))
  (log (concat "  💥 Allocation: I:" (string (round (* isru_allocation 1000))) "‰ G:" (string (round (* greenhouse_allocation 1000))) "‰ B:" (string (round (* building_allocation 1000))) "‰"))
  (log (concat "  🏗️ Survival: O2:" (string o2_days) "d Food:" (string food_days) "d Water:" (string water_days) "d | Ration:" (string (round (* food_ration 100))) "%"))

  ;; ═══ DOMINATION OUTPUT ═══
  (concat "⚡🌌💥🏗️🚀 DOMINATION NEXUS Sol " (string sol) 
    " | Phase:" (cond
      (lightning_phase "LIGHTNING")
      (nuclear_phase "NUCLEAR")
      (supernova_phase "SUPERNOVA") 
      (hypernova_phase "HYPERNOVA")
      (quantum_phase "QUANTUM")
      (dimensional_phase "DIMENSIONAL")
      (universal_phase "UNIVERSAL")
      (omnipotent_phase "OMNIPOTENT")
      (true "DEFAULT"))
    " | CRI:" (string (round colony_risk_index))
    " | Deficit:" (string (round (* absolute_minimal_deficit 100))) "%"
    " | B:" (string (round (* building_allocation 1000))) "‰"
    " | M:" (string modules_built)
    " | R:" (string repair_bays_built)))