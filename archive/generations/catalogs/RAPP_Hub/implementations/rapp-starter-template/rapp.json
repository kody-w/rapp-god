{
  "name": "rapp-starter-template",
  "version": "1.0.0",
  "description": "Minimal boilerplate for starting a new RAPP implementation with best practices baked in",
  "author": "RAPP Hub",
  "license": "Apache-2.0",
  "repository": "https://github.com/kody-w/RAPP_Hub",
  "category": "starter",
  "tags": ["starter", "template", "boilerplate", "quickstart"],
  "features": [
    "Pre-configured project structure",
    "Basic agent loading",
    "Environment setup",
    "Example agent included",
    "Ready for RAPP Store dependencies"
  ],
  "stack": {
    "runtime": "python",
    "version": "3.11",
    "platform": "standalone",
    "ai": "openai"
  },
  "dependencies": {
    "rapp_store": {
      "agents": [],
      "skills": []
    },
    "python": [
      "openai>=1.0.0"
    ]
  },
  "scripts": {
    "setup": "pip install -r requirements.txt",
    "start": "python main.py",
    "test": "python -m pytest tests/"
  }
}
