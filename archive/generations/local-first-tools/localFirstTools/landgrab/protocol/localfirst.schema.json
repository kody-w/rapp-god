{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kody-w.github.io/localFirstTools/landgrab/protocol/localfirst.schema.json",
  "title": "LocalFirst Protocol bus message",
  "type": "object",
  "required": ["__lf", "channel", "payload", "ts"],
  "properties": {
    "__lf": { "const": 1, "description": "Protocol version." },
    "channel": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$", "description": "Lowercase-kebab channel name." },
    "payload": { "type": "object", "description": "Channel-specific body." },
    "ts": { "type": "integer", "description": "Epoch milliseconds." },
    "from": { "type": "string", "description": "Publisher identity id (lf-xxxx)." }
  },
  "additionalProperties": true
}
