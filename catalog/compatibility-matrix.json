{
  "schema": "rapp-god-compatibility-matrix/1",
  "default": {
    "authoritative": false,
    "runnable": false,
    "currentness": "unknown",
    "failure_mode": "fail-closed"
  },
  "profiles": [
    {
      "id": "rapp1-chat-http/1",
      "surface": "/chat",
      "authority": "rapp/1 rev-5 structural",
      "request": {
        "required": ["user_input"],
        "optional": ["session_id", "idempotency_key"],
        "unrecognized_fields": "ignored"
      },
      "success": {
        "exact_fields": ["response", "agent_logs", "session_id"]
      },
      "invalid": {
        "http_status": 422,
        "exact_error": {
          "code": "malformed-request",
          "step": null
        }
      },
      "registration": "non-registered-pre-acceptance",
      "runnable": true,
      "owner_gated_execution": true
    },
    {
      "id": "rapp-agent-python/1",
