{
  "schema": "rapp-god-workspace/2",
  "workspace": "assimilated-monorepo-and-append-only-observatory",
  "dependency_policy": "component-local-with-target-owned-overlays",
  "universal_dependency_manager": null,
  "publish_policy": "owner-gated-no-automatic-component-publish",
  "tasks": [
    {
      "id": "semantic-catalog-check",
      "argv": ["python3", "tools/semantic_catalog.py", "--check"],
      "cwd": ".",
      "depends_on": [],
      "runtime": "Python >=3.9 stdlib",
      "operating_systems": ["linux", "macos", "windows-sparse"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    },
    {
      "id": "test-catalog-check",
      "argv": ["python3", "tools/test_catalog.py", "--check"],
      "cwd": ".",
      "depends_on": ["semantic-catalog-check"],
      "runtime": "Python >=3.9 stdlib",
      "operating_systems": ["linux", "macos", "windows-sparse"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    },
    {
      "id": "portability-check",
      "argv": ["python3", "tools/portability.py", "--check"],
      "cwd": ".",
      "depends_on": [],
      "runtime": "Python >=3.9 stdlib",
      "operating_systems": ["linux", "macos", "windows-sparse"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    },
    {
      "id": "archive-proof-check",
      "argv": ["python3", "tools/archive_inventory.py", "check-public"],
      "cwd": ".",
      "depends_on": [],
      "runtime": "Python >=3.9 stdlib",
      "operating_systems": ["linux", "macos", "windows-sparse"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    },
    {
      "id": "refs-release-check",
      "argv": ["python3", "tools/ref_inventory.py", "--check-public"],
      "cwd": ".",
      "depends_on": [],
      "runtime": "Python >=3.9 stdlib",
      "operating_systems": ["linux", "macos", "windows-sparse"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    },
    {
      "id": "license-check",
      "argv": ["python3", "tools/license_inventory.py", "--check"],
      "cwd": ".",
      "depends_on": ["archive-proof-check"],
      "runtime": "Python >=3.9 stdlib",
      "operating_systems": ["linux", "macos", "windows-sparse"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    },
    {
      "id": "observatory-history-check",
      "argv": ["python3", "tools/observatory_history.py", "--check"],
      "cwd": ".",
      "depends_on": [],
      "runtime": "Python >=3.9 stdlib plus Git",
      "operating_systems": ["linux", "macos"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    },
    {
      "id": "staging-plan-check",
      "argv": ["python3", "tools/stage_materialized.py", "--check-plan"],
      "cwd": ".",
      "depends_on": ["archive-proof-check", "refs-release-check", "license-check"],
      "runtime": "Python >=3.9 stdlib plus Git",
      "operating_systems": ["linux", "macos"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    },
    {
      "id": "staged-secret-check",
      "argv": ["python3", "tools/staged_secret_scan.py", "--check"],
      "cwd": ".",
      "depends_on": ["staging-plan-check"],
      "runtime": "Python >=3.9 stdlib plus Git",
      "operating_systems": ["linux", "macos"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    },
    {
      "id": "rapp-map-wrapper-check",
      "argv": ["python3", "tools/wrappers/rapp_map_offline.py", "--check"],
      "cwd": ".",
      "depends_on": ["native-proof-check"],
      "runtime": "Python 3.12",
      "operating_systems": ["linux", "macos"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    },
    {
      "id": "rapp-spine-wrapper-check",
      "argv": ["python3", "tools/wrappers/rapp_spine_offline.py", "--check"],
      "cwd": ".",
      "depends_on": ["native-proof-check"],
      "runtime": "Python 3.12",
      "operating_systems": ["linux", "macos"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    },
    {
      "id": "ultracode-rdw-wrapper-check",
      "argv": ["python3", "tools/wrappers/ultracode_local_rdw.py", "--check"],
      "cwd": ".",
      "depends_on": ["semantic-catalog-check"],
      "runtime": "Python >=3.11",
      "operating_systems": ["linux", "macos"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    },
    {
      "id": "native-proof-check",
      "argv": ["python3", "tools/native_provenance.py", "--check"],
      "cwd": ".",
      "depends_on": [],
      "runtime": "Python >=3.9 stdlib plus Git",
      "operating_systems": ["linux", "macos"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    },
    {
      "id": "source-capture-check",
      "argv": ["python3", "tools/source_capture.py", "--check"],
      "cwd": ".",
      "depends_on": ["native-proof-check"],
      "runtime": "Python >=3.9 stdlib plus Git",
      "operating_systems": ["linux", "macos"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    },
    {
      "id": "compat-tests",
      "argv": ["python3", "-m", "unittest", "tests.test_compat", "-v"],
      "cwd": ".",
      "depends_on": [],
      "runtime": "Python >=3.9 stdlib",
      "operating_systems": ["linux", "macos", "windows-sparse"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    },
    {
      "id": "observatory-no-net",
      "argv": ["python3", "build_god.py", "--no-net"],
      "cwd": ".",
      "depends_on": ["native-proof-check"],
      "runtime": "Python >=3.9 stdlib",
      "operating_systems": ["linux", "macos"],
      "network": false,
      "outputs": ["registry.json", "api/v1/status.json", "api/v1/badge.json"],
      "publish_owner": "rapp-god-observatory-owner"
    },
    {
      "id": "integrity-tests",
      "argv": ["python3", "-m", "unittest", "tests.test_assimilation", "tests.test_compat", "tests.test_wrappers", "tests.test_quarantine_matching", "-v"],
      "cwd": ".",
      "depends_on": [
        "semantic-catalog-check",
        "test-catalog-check",
        "portability-check",
        "archive-proof-check",
        "refs-release-check",
        "license-check",
        "observatory-history-check",
        "staging-plan-check",
        "staged-secret-check",
        "rapp-map-wrapper-check",
        "rapp-spine-wrapper-check",
        "ultracode-rdw-wrapper-check",
        "native-proof-check",
        "source-capture-check",
        "compat-tests",
        "observatory-no-net"
      ],
      "runtime": "Python >=3.9 stdlib plus Git",
      "operating_systems": ["linux", "macos"],
      "network": false,
      "outputs": [],
      "publish_owner": "none"
    }
  ],
  "overlays": [
    {
      "id": "ultracode-local-rdw",
      "from": "src/workflows/rapp-ultracode",
      "to": "src/workflows/rapp-dynamic-workflows",
      "record": "workspace/overlays/ultracode-rdw.json",
      "modifies_imported_manifest": false
    }
  ],
  "release_metadata": {
    "view": "catalog/release-view.json",
    "payload_overlays": "catalog/release-overlays.json",
    "production_head_label": "production-head"
  },
  "topology": {
    "services": "catalog/service-topology.json",
    "runtime_profiles": "catalog/runtime-profiles.jsonl",
    "unresolved_external_dependencies": "catalog/service-topology.json"
  },
  "test_plan": {
    "component_suites": "catalog/test-suites.jsonl",
    "upstream_baselines": "provenance/upstream-test-baselines.json",
    "policy": "Root automation runs target-owned allowlisted tasks only"
  },
  "provenance": {
    "sources": "provenance/sources.lock.json",
    "files": "provenance/files.jsonl",
    "native_files": "provenance/native-files.jsonl",
    "commit_objects": "provenance/commit-objects.jsonl",
    "archive_members": "provenance/archive-members.jsonl",
    "archive_proof": "provenance/archive-audit-proof.json",
    "refs": "provenance/refs.jsonl",
    "releases": "provenance/releases.jsonl",
    "release_assets": "provenance/release-assets.jsonl"
  },
  "windows": {
    "checkout": "no-checkout-plus-sparse",
    "instructions": "docs/WINDOWS_SPARSE_CHECKOUT.md",
    "portability_report": "catalog/portability.json"
  }
}
