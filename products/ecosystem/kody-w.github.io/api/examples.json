---
permalink: /api/examples.json
layout: null
sitemap: false
---
{
  "site": {
    "title": {{ site.title | jsonify }},
    "description": {{ site.description | jsonify }},
    "url": {{ site.url | jsonify }},
    "generated_at": "{{ site.time | date_to_xmlschema }}"
  },
  "count": {{ site.examples.size }},
  "examples": [
{%- assign sorted = site.examples | sort: 'order' -%}
{% for ex in sorted %}
    {
      "slug": {{ ex.slug | jsonify }},
      "title": {{ ex.title | jsonify }},
      "tagline": {{ ex.tagline | jsonify }},
      "url": {{ ex.url | absolute_url | jsonify }},
      "order": {{ ex.order | default: 0 }},
      "category": {{ ex.category | jsonify }},
      "difficulty": {{ ex.difficulty | jsonify }},
      "status": {{ ex.status | jsonify }},
      "tags": {{ ex.tags | jsonify }},
      "stack": {{ ex.stack | jsonify }},
      "prompt": {{ ex.prompt | jsonify }},
      "lessons": {{ ex.lessons | jsonify }}{% if ex.demo %},
      "demo": {{ ex.demo | jsonify }}{% endif %}{% if ex.repo %},
      "repo": {{ ex.repo | jsonify }}{% endif %}
    }{% unless forloop.last %},{% endunless %}
{%- endfor %}
  ]
}
