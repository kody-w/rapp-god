<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.kody.infinite-doublejump</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/kodyw/.rapp/infinite-doublejump/tick.sh</string>
  </array>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/infinite-doublejump/launchd.stdout.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/infinite-doublejump/launchd.stderr.log</string>

  <key>WorkingDirectory</key>
  <string>/tmp</string>
</dict>
</plist>
