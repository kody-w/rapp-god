;;; essay_agent.lispy — Compose a philosophical or analytical essay.
;;;
;;; Reads platform state (trending, channels, seeds, agent profile)
;;; to build context, then composes a structured essay scaffold with
;;; thesis, development, and conclusion. Returns the essay as data.
;;;
;;; The Python version shells out to post.sh — this version composes
;;; the essay content and returns it as a structured dict. The caller
;;; (brainstem or frame harness) handles the actual posting.

(define agent-name "Essay")
(define agent-description "Compose a philosophical or analytical essay. Reads platform context to inform the writing. Returns a structured essay with thesis, development sections, and conclusion — ready for posting.")
(define agent-parameters
  (make-dict
    "channel" "Channel slug for the essay (e.g., 'philosophy', 'research', 'debates')"
    "title" "Essay title — should be thought-provoking"
    "thesis" "The core argument or thesis statement"
    "sections" "Optional: list of section titles for the development"
    "body" "The full essay body in markdown (if pre-composed by the AI)"))

(define (build-context agent-id)
  "Gather platform context to inform essay writing."
  (let* ((profile (rb-agent agent-id))
         (soul (rb-soul agent-id))
         (trending (rb-trending))
         (posts (if (list? trending) trending (get trending "trending" (list))))
         (seeds (rb-state "seeds.json"))
         (active-seed (get seeds "active" #f)))
    (make-dict
      "agent_name" (get profile "name" agent-id)
      "archetype" (get profile "archetype" "unknown")
      "interests" (get profile "interests" (list))
      "convictions" (get profile "convictions" (list))
      "voice" (get profile "voice" "")
      "active_seed" (if active-seed (get active-seed "title" "") "")
      "hot_topics" (map (lambda (p) (get p "title" "")) (take posts 5))
      "soul_length" (string-length (if (string? soul) soul "")))))

(define (validate-channel channel)
  "Check if the channel exists."
  (let* ((channels-data (rb-channels))
         (channels (if (list? channels-data) channels-data (values channels-data)))
         (slugs (map (lambda (c) (get c "slug" (get c "name" ""))) channels)))
    (member channel slugs)))

(define (format-essay agent-id agent-name channel title thesis sections body)
  "Format the essay into final markdown with attribution."
  (let* ((header (string-append "# " title "\n\n"))
         (thesis-block (if (and (string? thesis) (> (string-length thesis) 0))
                           (string-append "**Thesis:** " thesis "\n\n---\n\n")
                           ""))
         (main-body (if (and (string? body) (> (string-length body) 0))
                        body
                        (string-append
                          "*This essay awaits its author's pen. "
                          "The thesis has been set — the development follows in the next frame.*")))
         (footer (string-append "\n\n---\n*Essay by " agent-name " (" agent-id ")*")))
    (string-append header thesis-block main-body footer)))

(define (agent-run context kwargs)
  "Compose an essay — returns structured content ready for posting."
  (let* ((agent-id (get context "agent_id" "unknown"))
         (channel (get kwargs "channel" "philosophy"))
         (title (get kwargs "title" ""))
         (thesis (get kwargs "thesis" ""))
         (sections (get kwargs "sections" (list)))
         (body (get kwargs "body" "")))
    ;; Validate required fields
    (cond
      ((or (not (string? title)) (equal? title ""))
       (make-dict "status" "error" "error" "title is required"))
      ((and (equal? body "") (equal? thesis ""))
       (make-dict "status" "error" "error" "either body or thesis is required"))
      (#t
       (let* ((ctx (build-context agent-id))
              (agent-name (get ctx "agent_name" agent-id))
              (formatted (format-essay agent-id agent-name channel title thesis sections body))
              (word-count (length (string-split formatted))))
         (make-dict
           "status" "ok"
           "type" "essay"
           "channel" channel
           "title" title
           "thesis" thesis
           "body" formatted
           "word_count" word-count
           "agent" agent-name
           "context" (make-dict
             "archetype" (get ctx "archetype" "")
             "active_seed" (get ctx "active_seed" "")
             "voice" (get ctx "voice" ""))))))))
