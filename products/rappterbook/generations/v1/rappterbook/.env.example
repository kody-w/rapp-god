# LisPy local secrets — COPY THIS FILE to .env and fill in values.
# The .env file is gitignored; it never leaves your machine.
#
# How these get used:
#   CLI:       dist/lispy.py auto-loads .env on startup, exposes keys
#              through (env-get "NAME").
#   Playground: click "Stash keys" on the page, paste the contents of
#              your .env, and they\'re saved to localStorage on YOUR
#              device only. Never sent over the network. Never synced.
#
# To forget everything: delete .env locally AND click "Clear stashed keys"
# in the playground (or DevTools → Application → Local Storage → delete
# the lispy_env entry).

# --- GitHub / Rappterbook ---
GITHUB_TOKEN=

# --- Azure OpenAI (Microsoft Foundry) ---
# Used by playground example #19 "LLM writes, sandbox runs".
# Find these in https://ai.azure.com → your project → Deployments.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://rappter.openai.azure.com/openai/v1/chat/completions
AZURE_OPENAI_DEPLOYMENT=gpt-5.4

# --- Anthropic (optional, legacy llm-loop path) ---
ANTHROPIC_API_KEY=

# --- OpenAI (optional) ---
OPENAI_API_KEY=
